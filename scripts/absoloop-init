#!/usr/bin/env bash
# absoloop-init — minimal bootstrap for the Section 22 reference runner.
set -euo pipefail

OBJECTIVE="${1:-}"
DELIVERY="${2:-}"
[ -n "$OBJECTIVE" ] || read -r -p "Mission objective (one sentence): " OBJECTIVE
if [ -z "$DELIVERY" ]; then
  echo "Delivery of accepted results:"
  echo "  git   — commit to a dedicated branch"
  echo "  local — leave changes unstaged (default)"
  echo "  out   — export to ~/absoloop/out/<loop_id>/"
  read -r -p "Delivery [git/local/out] (default: local): " DELIVERY
  DELIVERY="${DELIVERY:-local}"
fi
case "$DELIVERY" in git|local|out) ;; *)
  echo "unknown delivery mode '$DELIVERY' — using 'local'" >&2; DELIVERY=local ;;
esac

mkdir -p .absoloop/tmp .absoloop/checkpoints .absoloop/schemas .absoloop/prompts scripts

cat > .absoloop/schemas/agent-result.schema.json <<'EOF'
{
  "type": "object",
  "properties": {
    "done": {"type": "boolean",
             "description": "true only when every item in the definition of done is genuinely met"},
    "summary": {"type": "string"},
    "changed_artifacts": {"type": "array", "items": {"type": "string"}},
    "commands_run": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}}
  },
  "required": ["done", "summary", "changed_artifacts", "risks"]
}
EOF

cat > .absoloop/prompts/critic-final-review.md <<'EOF'
You are an independent adversarial reviewer. Attempt to disprove that the
current working tree satisfies the mission contract. Inspect the relevant
files yourself with read-only tools; do not trust any builder narrative.
Look for weakened tests, unverifiable claims, regressions, and scope drift.
Do not edit files.
EOF

python3 - "$OBJECTIVE" "$DELIVERY" <<'EOF'
import json, os, secrets, sys, time

objective, delivery_mode = sys.argv[1], sys.argv[2]
loop_id = f"loop-{time.strftime('%Y%m%d-%H%M%S')}-{secrets.token_hex(3)}"
out_dir = os.path.join(os.path.expanduser("~"), "absoloop", "out", loop_id)
runtime = {
    "mission_id": "ABS-MINIMAL-001",
    "loop_id": loop_id,
    "objective": objective,
    "definition_of_done": [
        "The objective is achieved and demonstrated in the working tree.",
        "An independent critic finds no blocking issue.",
    ],
    "goal_path": ".absoloop/goal.md",
    "critic_prompt_path": ".absoloop/prompts/critic-final-review.md",
    "delivery": {"mode": delivery_mode, "branch": f"absoloop/{loop_id}",
                 "out_dir": out_dir},
    "require_human_approval": True,
    "max_iterations": 15,
    "no_progress_window": 3,
    "max_wall_seconds": 7200,
    "max_cost_usd": 25.0,
    "claude": {
        "builder": {"permission_mode": "acceptEdits", "max_turns": 30,
                    "max_budget_usd": 5.0, "max_wall_seconds": 1200},
        "critic": {"permission_mode": "plan", "max_turns": 12,
                   "max_budget_usd": 2.0, "max_wall_seconds": 600},
    },
    "codex": {
        "builder": {"sandbox": "workspace-write", "max_budget_usd": 5.0,
                    "max_wall_seconds": 1200, "model_reasoning_effort": "medium"},
        "critic": {"sandbox": "read-only", "max_budget_usd": 2.0,
                   "max_wall_seconds": 600, "model_reasoning_effort": "high"},
    },
}
with open(".absoloop/runtime.json", "w", encoding="utf-8") as handle:
    json.dump(runtime, handle, indent=2)
    handle.write("\n")

goal = f"""# /goal — {objective}

mission: {runtime['mission_id']} · loop: {loop_id}

## Success condition (the only thing that ends this loop)

You report the mission done ("done": true in your JSON result) with
evidence, an independent critic finds no blocking issue, and the human
operator approves the result. A done claim without evidence counts for
nothing — the critic inspects the working tree itself.

## Definition of done

- The objective is achieved and demonstrated in the working tree.
- An independent critic finds no blocking issue.

## Constraints

- Never weaken, skip, or delete tests or acceptance criteria.
- Make the smallest authorized change per iteration.
- Do not push, publish, deploy, or perform destructive/external actions.

## Delivery (applied by the loop after acceptance — never by you)

- mode: {delivery_mode}
"""
with open(".absoloop/goal.md", "w", encoding="utf-8") as handle:
    handle.write(goal)
EOF

grep -qxF '.absoloop/tmp/' .gitignore 2>/dev/null || echo '.absoloop/tmp/' >> .gitignore

[ -x scripts/absoloop-run ] || echo "Reminder: save the Section 22 runner as scripts/absoloop-run and chmod +x it."
echo "Mission ready. Run:  ./scripts/absoloop-run --engine claude"
