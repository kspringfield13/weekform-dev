#!/usr/bin/env python3
"""Absoloop mission runner — checkpointed builder ↔ critic repair loop.

Copied into projects as ``scripts/absoloop-run`` by ``bin/absoloop``. This file
is the authority for acceptance order and must stay Python 3.9+ stdlib-only.

Loop contract (do not weaken):
  1. Builder iterates under hard budgets (iterations / wall / dollars)
  2. On a "done" claim → optional integrity command
  3. Independent critic (PASS / HOLD / REJECT); unreadable ≠ pass
  4. Human gate (AWAITING_APPROVAL) before delivery externalization

Supporting concerns:
  - Thinking escalation via ``runtime.json.thinking_ladder``
  - Two-layer teams: this process is outer; the builder CLI is team lead
  - Live telemetry in ``.absoloop/tmp/`` for ``absoloop watch`` / ZComb
  - Durable ledger + state for resume / extend / abort
"""
from __future__ import annotations

import argparse
import contextlib
import copy
import hashlib
import json
import os
import pathlib
import re
import shutil
import subprocess
import sys
import textwrap
import threading
import time
from dataclasses import dataclass, asdict
from typing import Any, Callable

ROOT = pathlib.Path.cwd()
ABS = ROOT / ".absoloop"
TMP = ABS / "tmp"
CHECKPOINTS = ABS / "checkpoints"
STATE_PATH = ABS / "state.json"
LEDGER_PATH = ABS / "ledger.jsonl"
RUNTIME_PATH = ABS / "runtime.json"
RESULT_SCHEMA = ABS / "schemas" / "agent-result.schema.json"
# Live telemetry for 'absoloop watch' / 'absoloop status' — kept under tmp/
# (gitignored) so monitoring artifacts never leak into delivered commits.
MONITOR_PATH = TMP / "monitor.json"
LIVE_PATH = TMP / "live.jsonl"
# Mission skills: reusable capabilities the loop compounds across iterations.
# 'absoloop' seeds the loopers-toolbox into each engine's native project-skill
# discovery path (CLIs scan theirs at session startup); the builder
# creates/enhances further skills there via skill-creator.
ENGINE_SKILL_DIRS = {
    "claude": ".claude/skills",
    "codex": ".codex/skills",
    "grok": ".grok/skills",
}

# Two-layer teams: Absoloop spawns the Builder CLI; that Builder is the team
# lead and must fan out with native Agent Teams / subagents on complex work.
_DELEGATION_POSTURE = {
    "claude": (
        "## Builder role — you are the team lead\n"
        "Agent Teams are enabled. You are the Builder / lead, not a solo coder.\n"
        "For any multi-file, multi-component, or larger build (new feature, "
        "multi-game polish, cross-layer change, research+implement+test):\n"
        "1. Decompose into independent slices.\n"
        "2. Spawn teammates NOW with the Task tool (one message, multiple "
        "Task calls) — e.g. implementer, tester, polisher, reviewer.\n"
        "3. Give each teammate a clear owned slice and success criteria.\n"
        "4. Coordinate via the shared task list / SendMessage; synthesize "
        "results yourself.\n"
        "Do NOT implement the whole complex build serially alone. Solo only "
        "true one-file / one-function fixes."
    ),
    "codex": (
        "## Builder role — you are the team lead\n"
        "You are the Builder / lead, not a solo coder. For any multi-file, "
        "multi-component, or larger build: spawn subagents in parallel "
        "(implement / test / polish) before doing the work yourself. Ask for "
        "parallel agents explicitly. Solo only true one-file / one-function fixes."
    ),
    "grok": (
        "## Builder role — you are the team lead\n"
        "You are the Builder / lead, not a solo coder. For any multi-file, "
        "multi-component, or larger build: call `spawn_subagent` in parallel "
        "(research / build / review), prefer worktree isolation when files "
        "would conflict. Solo only true one-file / one-function fixes."
    ),
}


def skills_root(engine: str) -> pathlib.Path:
    return ROOT / ENGINE_SKILL_DIRS.get(engine, ".claude/skills")


def delegation_posture(engine: str) -> str:
    return _DELEGATION_POSTURE.get(engine, "")

# Thinking escalation: as the same failure repeats, both engines are pushed to
# spend more reasoning depth instead of re-trying the same shallow fix.
# The authoritative ladder is generated per mission by 'absoloop' into
# runtime.json ("thinking_ladder") and rendered in the /goal contract; this
# built-in ladder is only the fallback for projects scaffolded before ladders
# became per-mission. Each rung carries: the claude extended-thinking keyword,
# a MAX_THINKING_TOKENS budget exported to `claude -p`, the codex
# model_reasoning_effort, and a budget_scale that widens the builder's
# per-run wall-clock/cost caps so deep thinking is not cut off early.
DEFAULT_THINKING_LADDER: list[dict[str, Any]] = [
    {"repeats": "0 (fresh evidence)", "claude_keyword": "think",
     "claude_thinking_tokens": 4000, "codex_effort": "medium", "budget_scale": 1.0,
     "posture": "Plan briefly, act on the strongest hypothesis."},
    {"repeats": "1 (first repeat)", "claude_keyword": "think hard",
     "claude_thinking_tokens": 10000, "codex_effort": "high", "budget_scale": 1.25,
     "posture": "The obvious fix failed once — re-derive the failure from the "
                "evidence before editing anything."},
    {"repeats": "2 (second repeat)", "claude_keyword": "think harder",
     "claude_thinking_tokens": 16000, "codex_effort": "high", "budget_scale": 1.5,
     "posture": "Two identical failures mean your model of the problem is wrong. "
                "Enumerate at least three distinct hypotheses and test the most "
                "falsifiable one."},
    {"repeats": "3+ (final window)", "claude_keyword": "ultrathink",
     "claude_thinking_tokens": 31999, "codex_effort": "high", "budget_scale": 2.0,
     "posture": "Final window before the loop blocks. Step back to first "
                "principles, question your assumptions about the mission, and say "
                "so in your summary if the mission needs operator input."},
]

CODEX_EFFORT_RANK = {"minimal": 0, "low": 1, "medium": 2, "high": 3, "xhigh": 4}


def thinking_rung(runtime: dict[str, Any], state: "State") -> dict[str, Any]:
    """The escalation rung for the current repeated-failure count, from the
    mission's generated ladder when it is usable, else the built-in default."""
    ladder = runtime.get("thinking_ladder")
    if not (isinstance(ladder, list) and ladder
            and all(isinstance(rung, dict)
                    and str(rung.get("claude_keyword", "")).strip()
                    and rung.get("codex_effort") in CODEX_EFFORT_RANK
                    for rung in ladder)):
        ladder = DEFAULT_THINKING_LADDER
    return ladder[min(state.repeated_failure_count, len(ladder) - 1)]


CRITIC_SCHEMA: dict[str, Any] = {
    "type": "object",
    "additionalProperties": False,
    "properties": {
        "recommendation": {"type": "string", "enum": ["PASS", "HOLD", "REJECT"]},
        "blocking_findings": {"type": "array", "items": {"type": "string"}},
        "summary": {"type": "string"},
    },
    "required": ["recommendation", "blocking_findings", "summary"],
}


def openai_strict_json_schema(schema: dict[str, Any]) -> dict[str, Any]:
    """Deep-copy ``schema`` into OpenAI Structured Outputs strict form.

    Codex ``--output-schema`` forwards the file to OpenAI's
    ``response_format`` / ``codex_output_schema``, which rejects any object
    node missing ``additionalProperties: false`` and any property omitted
    from ``required``. Claude/Grok tolerate the looser shape; normalizing
    here keeps a single portable schema source.
    """
    out = copy.deepcopy(schema)

    def walk(node: Any) -> None:
        if not isinstance(node, dict):
            return
        if node.get("type") == "object" or "properties" in node:
            node["additionalProperties"] = False
            props = node.get("properties")
            if isinstance(props, dict) and props:
                node["required"] = list(props.keys())
                for child in props.values():
                    walk(child)
        items = node.get("items")
        if isinstance(items, dict):
            walk(items)
        elif isinstance(items, list):
            for child in items:
                walk(child)
        for key in ("anyOf", "oneOf", "allOf"):
            alts = node.get(key)
            if isinstance(alts, list):
                for child in alts:
                    walk(child)
        for key in ("$defs", "definitions"):
            defs = node.get(key)
            if isinstance(defs, dict):
                for child in defs.values():
                    walk(child)

    walk(out)
    return out


@dataclass
class State:
    mission_id: str
    status: str = "READY"
    iteration: int = 0
    started_at: float = 0.0
    cost_usd: float = 0.0
    tokens_total: int = 0
    inexact_cost_events: int = 0
    last_failure_fingerprint: str | None = None
    repeated_failure_count: int = 0
    latest_agent_result: str | None = None
    latest_critic_findings: str | None = None
    latest_checkpoint: str | None = None
    stop_reason: str | None = None
    human_feedback: str | None = None


@dataclass
class AgentRun:
    exit_code: int
    cost_usd: float           # exact when parsed; the configured cap otherwise
    cost_is_exact: bool
    limit_reached: str | None
    output_path: pathlib.Path
    tokens: int | None = None  # total tokens processed, when the engine reported usage


def fmt_tokens(tokens: Any) -> str:
    """Human token count for cost lines: 12.3k tokens."""
    return (f"{float(tokens) / 1000:.1f}k tokens"
            if isinstance(tokens, (int, float)) and tokens > 0 else "")


# ---------------------------------------------------------------------------
# Console output: colored, timestamped progress lines. Colors follow the
# terminal (disabled when stdout is not a tty or NO_COLOR is set).
# ---------------------------------------------------------------------------

_COLOR = sys.stdout.isatty() and not os.environ.get("NO_COLOR")
_STYLES = {"ok": "32", "warn": "33", "err": "31", "act": "36", "dim": "2",
           "bold": "1"}


def tint(style: str, text: str) -> str:
    code = _STYLES.get(style)
    return f"\033[{code}m{text}\033[0m" if (_COLOR and code) else text


def say(message: str, style: str | None = None) -> None:
    """Live progress line so the operator can watch the loop working."""
    stamp = tint("dim", f"[absoloop {time.strftime('%H:%M:%S')}]")
    print(f"{stamp} {tint(style, message) if style else message}", flush=True)


class MonitorFile:
    """The loop's live telemetry surface.

    Two artifacts, both safe to read at any moment from another process:
      .absoloop/monitor.json — atomically-replaced snapshot of the loop's
        current phase, budgets, spend, and last observed agent activity
        (read by 'absoloop watch' and 'absoloop status');
      .absoloop/live.jsonl — append-only feed of individual agent actions
        (tool calls, commands, messages) streamed out of the engine.
    Every write is best-effort: telemetry must never kill the loop."""

    HEARTBEAT_EVERY = 5.0

    def __init__(self) -> None:
        self._lock = threading.Lock()
        self._data: dict[str, Any] = {"schema": 1, "pid": os.getpid()}
        self._last_flush = 0.0

    def update(self, **fields: Any) -> None:
        with self._lock:
            self._data.update(fields)
            self._flush()

    def touch(self) -> None:
        """Refresh the heartbeat so watchers can tell a live loop from a
        crashed one, without rewriting the file on every activity line."""
        with self._lock:
            if time.time() - self._last_flush >= self.HEARTBEAT_EVERY:
                self._flush()

    def _flush(self) -> None:
        self._data["heartbeat_ts"] = time.time()
        try:
            atomic_write_json(MONITOR_PATH, self._data)
        except OSError:
            pass
        self._last_flush = time.time()

    def activity(self, agent: str, kind: str, detail: str) -> None:
        detail = " ".join(str(detail).split())[:300]
        event = {"ts": time.time(), "agent": agent, "kind": kind, "detail": detail}
        try:
            with LIVE_PATH.open("a", encoding="utf-8") as handle:
                handle.write(json.dumps(event, sort_keys=True) + "\n")
        except OSError:
            pass
        with self._lock:
            self._data["last_activity"] = event
            self._data["activity_count"] = int(self._data.get("activity_count", 0)) + 1
            if time.time() - self._last_flush >= 1.0:
                self._flush()


MONITOR = MonitorFile()


@contextlib.contextmanager
def heartbeat(label: str, interval: float = 30.0):
    """Print a periodic heartbeat while a long blocking step runs, so a slow
    agent or check never looks like a hang. Also keeps monitor.json fresh so
    'absoloop watch' can prove the loop is alive."""
    started = time.time()
    done = threading.Event()

    def beat() -> None:
        last_line = started
        while not done.wait(min(interval, MonitorFile.HEARTBEAT_EVERY)):
            MONITOR.touch()
            if time.time() - last_line >= interval:
                say(f"{label}... still running ({time.time() - started:.0f}s elapsed)", "dim")
                last_line = time.time()

    thread = threading.Thread(target=beat, daemon=True)
    thread.start()
    try:
        yield
    finally:
        done.set()
        thread.join(timeout=1)


def report_spend(state: "State", runtime: dict[str, Any]) -> None:
    """Running cost report after every paid step, with early warnings so the
    cap never arrives as a surprise."""
    cap = float(runtime["max_cost_usd"])
    pct = 100 * state.cost_usd / cap if cap else 0.0
    remaining = max(0.0, cap - state.cost_usd)
    MONITOR.update(cost_usd=round(state.cost_usd, 4), max_cost_usd=cap,
                   tokens_total=state.tokens_total,
                   inexact_cost_events=state.inexact_cost_events)
    tokens = f" ({fmt_tokens(state.tokens_total)})" if fmt_tokens(state.tokens_total) else ""
    say(f"spend: ${state.cost_usd:.2f}{tokens} of ${cap:.2f} mission budget "
        f"({pct:.0f}% used, ${remaining:.2f} left)")
    if state.inexact_cost_events:
        say(f"spend: {state.inexact_cost_events} run(s) had no exact cost and were "
            "counted at their full per-run cap")
    if pct >= 90:
        say("WARNING: over 90% of the mission cost budget used — the loop will "
            "stop at the cap; raise max_cost_usd in .absoloop/runtime.json to continue")
    elif pct >= 75:
        say("notice: over 75% of the mission cost budget used")


def load_json(path: pathlib.Path) -> dict[str, Any]:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError as exc:
        raise SystemExit(f"Missing required file: {path}") from exc
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Invalid JSON in {path}: {exc}") from exc


def atomic_write_json(path: pathlib.Path, value: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temp = path.with_suffix(path.suffix + ".tmp")
    temp.write_text(json.dumps(value, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    temp.replace(path)


def append_ledger(event: dict[str, Any]) -> None:
    LEDGER_PATH.parent.mkdir(parents=True, exist_ok=True)
    event = {"ts": time.time(), **event}
    with LEDGER_PATH.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(event, sort_keys=True) + "\n")


def checkpoint(state: State, label: str) -> None:
    CHECKPOINTS.mkdir(parents=True, exist_ok=True)
    path = CHECKPOINTS / f"{state.iteration:04d}-{label}.json"
    state.latest_checkpoint = str(path.relative_to(ROOT))
    atomic_write_json(path, asdict(state))
    atomic_write_json(STATE_PATH, asdict(state))


def normalized_fingerprint(text: str) -> str:
    # Replace volatile-looking tokens before hashing.
    normalized_lines: list[str] = []
    for line in text.splitlines():
        line = line.strip()
        if not line:
            continue
        if line.startswith(("time=", "duration=", "timestamp=", "wall_seconds=")):
            continue
        normalized_lines.append(line)
    normalized = "\n".join(sorted(set(normalized_lines)))
    return hashlib.sha256(normalized.encode("utf-8")).hexdigest()[:16]


def tree_fingerprint() -> str | None:
    """Fingerprint of the working tree's uncommitted state, used to detect
    iterations that change nothing. None when git cannot answer."""
    if not shutil.which("git"):
        return None
    status = subprocess.run(["git", "status", "--porcelain", "-uall"], cwd=ROOT,
                            text=True, capture_output=True, check=False)
    if status.returncode != 0:
        return None
    diff = subprocess.run(["git", "diff"], cwd=ROOT,
                          text=True, capture_output=True, check=False)
    combined = status.stdout + "\n" + diff.stdout
    return hashlib.sha256(combined.encode("utf-8")).hexdigest()[:16]


def run_command(command: str, log_path: pathlib.Path, timeout: int,
                label: str = "check") -> subprocess.CompletedProcess[str]:
    log_path.parent.mkdir(parents=True, exist_ok=True)
    say(f"{label}: $ {command}")
    started = time.time()
    # Check commands run under bash where available (macOS/Linux, Git Bash
    # on Windows); otherwise fall back to the platform shell (cmd.exe).
    bash = shutil.which("bash")
    argv: list[str] | str = [bash, "-lc", command] if bash else command
    try:
        with heartbeat(label):
            result = subprocess.run(
                argv,
                shell=bash is None,
                cwd=ROOT,
                text=True,
                capture_output=True,
                timeout=timeout,
                check=False,
                env=os.environ.copy(),
            )
    except subprocess.TimeoutExpired as exc:
        output = (exc.stdout or "") + "\n" + (exc.stderr or "")
        log_path.write_text(output + "\nCHECK_TIMEOUT\n", encoding="utf-8")
        say(f"{label}: TIMED OUT after {timeout}s (log: {log_path.relative_to(ROOT)})")
        return subprocess.CompletedProcess(command, 124, exc.stdout or "", exc.stderr or "timeout")

    combined = (
        f"$ {command}\n"
        f"exit_code={result.returncode}\n"
        f"wall_seconds={time.time() - started:.3f}\n\n"
        f"--- stdout ---\n{result.stdout}\n"
        f"--- stderr ---\n{result.stderr}\n"
    )
    log_path.write_text(combined, encoding="utf-8")
    if result.returncode == 0:
        say(f"{label}: PASSED in {time.time() - started:.1f}s")
    else:
        stderr_tail = " | ".join(result.stderr.strip().splitlines()[-3:]) or "(no stderr)"
        say(f"{label}: FAILED exit {result.returncode} in {time.time() - started:.1f}s "
            f"— {stderr_tail} (log: {log_path.relative_to(ROOT)})")
    return result


def agent_structured(out_path: pathlib.Path) -> dict[str, Any] | None:
    """The agent's structured result, whichever engine produced it.
    Handles both shapes: claude's CLI payload (structured_output/result) and
    codex's ``-o`` file, which is the structured result itself."""
    try:
        payload = json.loads(out_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    if not isinstance(payload, dict):
        return None
    structured = payload.get("structured_output")
    return structured if isinstance(structured, dict) else payload


def _clean_list(value: Any, limit: int) -> tuple[list[str], int]:
    """First `limit` non-empty string items plus how many were left out."""
    items = [str(item).strip() for item in value
             if isinstance(item, (str, int, float)) and str(item).strip()] \
        if isinstance(value, list) else []
    return items[:limit], max(0, len(items) - limit)


def render_agent_report(out_path: pathlib.Path, label: str) -> None:
    """Render the agent's own structured report to the console — done claim,
    summary, artifacts, commands, risks — so the operator sees exactly what
    the agent says it did, not just exit codes and cost. Tolerates any
    payload shape; a missing or garbled report is itself reported."""
    structured = agent_structured(out_path)
    if structured is None:
        say(f"{label} report: none — the run produced no readable JSON result "
            f"(raw output: {out_path.relative_to(ROOT)})", "warn")
        return
    try:
        payload = json.loads(out_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        payload = {}
    if not isinstance(payload, dict):
        payload = {}

    done = structured.get("done")
    if isinstance(done, bool):
        claim = tint("ok", "reports DONE") if done else "reports not done yet"
        say(f"{label} {claim}", "bold" if done else None)

    message = structured.get("summary")
    if not (isinstance(message, str) and message.strip()):
        message = payload.get("result")
    if isinstance(message, str) and message.strip():
        condensed = " ".join(message.split())
        for line in textwrap.wrap(condensed, width=88)[:6]:
            say(f"{label} says: {line}")
        if len(textwrap.wrap(condensed, width=88)) > 6:
            say(f"{label} says: … (full report: {out_path.relative_to(ROOT)})", "dim")

    artifacts, more = _clean_list(structured.get("changed_artifacts"), 8)
    if artifacts:
        say(f"{label} changed: " + ", ".join(artifacts)
            + (f" (+{more} more)" if more else ""))
    commands, more = _clean_list(structured.get("commands_run"), 5)
    if commands:
        say(f"{label} ran: " + " ; ".join(commands)
            + (f" (+{more} more)" if more else ""))
    risks, more = _clean_list(structured.get("risks"), 6)
    for risk in risks:
        say(f"{label} flags risk: {risk}", "warn")
    if more:
        say(f"{label} flags {more} more risk(s) — see {out_path.relative_to(ROOT)}", "warn")


# ---------------------------------------------------------------------------
# Engine event streaming: both engines emit machine-readable event lines while
# they work. The loop parses them live, narrates each meaningful action to the
# console, and mirrors it into the monitor feed so 'absoloop watch' shows what
# the agent is doing *right now* — not just that something is running.
# ---------------------------------------------------------------------------

def stream_process(command: list[str], wall_seconds: float,
                   on_line: Callable[[str], None],
                   env: dict[str, str] | None = None,
                   ) -> tuple[int, bool, str, str]:
    """Run a command, feeding each stdout line to on_line as it arrives.

    Returns (exit_code, timed_out, stdout, stderr). Enforces the wall-clock
    bound by killing the process; reader threads make this safe on every
    platform (no select() on pipes, which Windows lacks). on_line failures
    are swallowed — narration must never break the run itself."""
    proc = subprocess.Popen(command, cwd=ROOT, text=True, encoding="utf-8",
                            errors="replace", stdout=subprocess.PIPE,
                            stderr=subprocess.PIPE, stdin=subprocess.DEVNULL,
                            env=env)
    out_lines: list[str] = []
    err_chunks: list[str] = []

    def read_stdout() -> None:
        assert proc.stdout is not None
        for line in proc.stdout:
            out_lines.append(line)
            try:
                on_line(line.rstrip("\n"))
            except Exception:
                pass

    def read_stderr() -> None:
        assert proc.stderr is not None
        err_chunks.append(proc.stderr.read() or "")

    readers = [threading.Thread(target=read_stdout, daemon=True),
               threading.Thread(target=read_stderr, daemon=True)]
    for thread in readers:
        thread.start()
    timed_out = False
    try:
        proc.wait(timeout=wall_seconds)
    except subprocess.TimeoutExpired:
        timed_out = True
        proc.kill()
        proc.wait()
    for thread in readers:
        thread.join(timeout=5)
    return proc.returncode, timed_out, "".join(out_lines), "".join(err_chunks)


def _first_of(mapping: dict[str, Any], *keys: str) -> str:
    for key in keys:
        value = mapping.get(key)
        if isinstance(value, str) and value.strip():
            return value.strip()
    return ""


def describe_tool_use(name: str, tool_input: Any) -> str:
    """One human line for a tool call: the tool plus its most telling input."""
    if not isinstance(tool_input, dict):
        tool_input = {}
    detail = _first_of(tool_input, "command", "file_path", "path", "pattern",
                       "query", "url", "description", "prompt")
    if name == "TodoWrite":
        detail = detail or "updating its task plan"
    if not detail and tool_input:
        detail = json.dumps(tool_input, sort_keys=True)
    return f"{name}: {detail}" if detail else name


def claude_stream_events(line: str) -> list[tuple[str, str]]:
    """(kind, detail) narration for one claude stream-json line."""
    try:
        event = json.loads(line)
    except json.JSONDecodeError:
        return []
    if not isinstance(event, dict):
        return []
    etype = event.get("type")
    if etype == "system" and event.get("subtype") == "init":
        model = event.get("model") or "?"
        return [("start", f"session started (model {model})")]
    if etype == "assistant":
        message = event.get("message")
        content = message.get("content") if isinstance(message, dict) else None
        described: list[tuple[str, str]] = []
        for block in content if isinstance(content, list) else []:
            if not isinstance(block, dict):
                continue
            if block.get("type") == "tool_use":
                name = str(block.get("name", "tool"))
                tool_input = block.get("input")
                # Surface Agent Teams / subagent spawns clearly in watch.
                if name in ("Task", "Agent", "SpawnAgent", "spawn_subagent",
                            "spawn_agent"):
                    detail = describe_tool_use(name, tool_input)
                    described.append(("tool", f"spawn teammate · {detail}"))
                else:
                    described.append(("tool", describe_tool_use(name, tool_input)))
            elif block.get("type") == "text":
                text = " ".join(str(block.get("text", "")).split())
                if text:
                    described.append(("say", text))
        return described
    return []


def grok_stream_events(line: str) -> list[tuple[str, str]]:
    """(kind, detail) narration for one grok streaming-json line."""
    try:
        event = json.loads(line)
    except json.JSONDecodeError:
        return []
    if not isinstance(event, dict):
        return []
    etype = str(event.get("type", ""))
    if etype == "text":
        text = " ".join(str(event.get("data", "")).split())
        return [("say", text)] if text else []
    if etype == "thought":
        text = " ".join(str(event.get("data", "")).split())
        return [("think", text)] if text else []
    if etype == "error":
        return [("say", str(event.get("message", "error"))[:200])]
    if etype == "end":
        return [("start", "run completed")]
    # Preserve unknown types (incl. subagent markers) for watch/live.jsonl.
    if etype and etype not in ("heartbeat",):
        preview = json.dumps(event, sort_keys=True)[:160]
        return [("tool", f"{etype}: {preview}")]
    return []


def _summary_from_result_blob(text: str) -> str:
    """If text is a done/summary JSON result blob, return just the summary.

    Codex often prints the structured mission result as an agent_message.
    Prefer the human summary over the raw JSON wrapper in watch/ZComb.
    """
    blob = text.strip()
    if not blob.startswith("{"):
        return ""
    data: Any = None
    try:
        data = json.loads(blob)
    except (json.JSONDecodeError, TypeError):
        try:
            data, _ = json.JSONDecoder().raw_decode(blob)
        except (json.JSONDecodeError, TypeError):
            data = None
    if isinstance(data, dict) and "done" in data and "summary" in data:
        return str(data.get("summary") or "").strip()
    # Truncated mid-feed: {"done":false,"summary":"partial…
    match = re.match(
        r'^\s*\{\s*"done"\s*:\s*(?:true|false)\s*,\s*"summary"\s*:\s*"(.*)$',
        blob,
        flags=re.IGNORECASE | re.DOTALL,
    )
    if not match:
        return ""
    rest = match.group(1)
    chars: list[str] = []
    escaped = False
    for ch in rest:
        if escaped:
            if ch == "n":
                chars.append("\n")
            elif ch == "t":
                chars.append("\t")
            elif ch == '"':
                chars.append('"')
            elif ch == "\\":
                chars.append("\\")
            else:
                chars.append(ch)
            escaped = False
            continue
        if ch == "\\":
            escaped = True
            continue
        if ch == '"':
            break
        chars.append(ch)
    return "".join(chars).strip()


def _codex_collab_detail(item: dict[str, Any]) -> tuple[str, str] | None:
    """Map Codex collab_tool_call items to live.jsonl narration.

    ZComb Agent cards only appear for lines prefixed with
    ``spawn teammate · `` (same contract as Claude Task/Agent tool_use).
    Codex emits native multi-agent work as ``collab_tool_call`` /
    ``spawn_agent`` — without this mapping, the Agents panel stays at
    Builder + Critic only.
    """
    tool = str(item.get("tool") or "").strip()
    tool_key = tool.lower().replace("-", "_")
    focus = " ".join(
        _first_of(item, "prompt", "message", "task_name", "description").split()
    )
    if tool_key in ("spawn_agent", "spawnagent"):
        detail = f"spawn_agent: {focus}" if focus else "spawn_agent"
        return ("tool", f"spawn teammate · {detail}")
    if not tool_key:
        return None
    if focus:
        return ("tool", f"{tool_key}: {focus}")
    receivers = item.get("receiver_thread_ids")
    if isinstance(receivers, list) and receivers:
        return ("tool", f"{tool_key}: {', '.join(str(r) for r in receivers[:3])}")
    return ("tool", tool_key)


def codex_stream_events(line: str) -> list[tuple[str, str]]:
    """(kind, detail) narration for one codex --json event line."""
    try:
        event = json.loads(line)
    except json.JSONDecodeError:
        return []
    if not isinstance(event, dict):
        return []
    etype = str(event.get("type", ""))
    item = event.get("item") if isinstance(event.get("item"), dict) else {}
    itype = str(item.get("item_type") or item.get("type") or "")
    if etype == "thread.started":
        return [("start", "session started")]
    # Collab spawns: narrate on item.started so teammate cards appear while
    # the subagent runs. Non-spawn collab tools (wait/send_input/close)
    # narrate on completed. Completed spawn is skipped to avoid double
    # "joins the team" rows when Codex emits both lifecycle events.
    if itype == "collab_tool_call" and etype in ("item.started", "item.completed"):
        tool_key = str(item.get("tool") or "").strip().lower().replace("-", "_")
        is_spawn = tool_key in ("spawn_agent", "spawnagent")
        if is_spawn:
            if etype != "item.started":
                return []
            narrated = _codex_collab_detail(item)
            return [narrated] if narrated else []
        if etype == "item.completed":
            narrated = _codex_collab_detail(item)
            return [narrated] if narrated else []
        return []
    if etype == "item.completed":
        if itype == "command_execution":
            exit_code = item.get("exit_code")
            suffix = "" if exit_code in (0, None) else f" (exit {exit_code})"
            return [("tool", f"ran: {_first_of(item, 'command')}{suffix}")]
        if itype == "file_change":
            changes = item.get("changes")
            paths = [str(c.get("path", "?")) for c in changes
                     if isinstance(c, dict)] if isinstance(changes, list) else []
            return [("tool", "edited: " + (", ".join(paths[:6]) or "files"))]
        if itype in ("agent_message", "reasoning"):
            text = " ".join(_first_of(item, "text", "summary").split())
            if text:
                plain = _summary_from_result_blob(text)
                if plain:
                    text = plain
                kind = "say" if itype == "agent_message" else "think"
                return [(kind, text)]
        if itype in ("mcp_tool_call", "web_search"):
            return [("tool", f"{itype}: "
                     + (_first_of(item, "tool", "query", "server") or "…"))]
    if etype == "turn.completed" and isinstance(event.get("usage"), dict):
        usage = event["usage"]
        return [("usage", f"turn complete — {usage.get('input_tokens', '?')} in / "
                          f"{usage.get('output_tokens', '?')} out tokens")]
    if etype == "error":
        return [("error", _first_of(event, "message") or "engine error")]
    return []


def narrate(label: str, events: list[tuple[str, str]]) -> None:
    """Print streamed agent actions and mirror them into the monitor feed."""
    for kind, detail in events:
        MONITOR.activity(label, kind, detail)
        if kind == "say":
            shown = detail if len(detail) <= 160 else detail[:157] + "…"
            say(f"{label} · {shown}", "act")
        elif kind == "think":
            shown = detail if len(detail) <= 120 else detail[:117] + "…"
            say(f"{label} · thinking: {shown}", "dim")
        elif kind == "error":
            say(f"{label} · engine error: {detail}", "err")
        elif kind == "usage":
            say(f"{label} · {detail}", "dim")
        else:
            shown = detail if len(detail) <= 140 else detail[:137] + "…"
            say(f"{label} → {shown}")


def load_goal(runtime: dict[str, Any]) -> str:
    """The mission's /goal contract (generated at scaffold time by
    'absoloop'). Falls back to a minimal inline contract so old projects
    without goal.md still get a firm stop condition."""
    goal_path = ROOT / runtime.get("goal_path", ".absoloop/goal.md")
    if goal_path.is_file():
        return goal_path.read_text(encoding="utf-8", errors="replace")
    return (
        f"# /goal — {runtime['objective']}\n\n"
        "## Success condition (the only thing that ends this loop)\n\n"
        "You report the mission done (\"done\": true in your JSON result), an "
        "independent critic finds no blocking issue, and the human operator "
        "approves the result.\n\n"
        "## Definition of done\n\n"
        + "\n".join(f"- {item}" for item in runtime.get("definition_of_done", []))
        + "\n"
    )


def list_skills(engine: str) -> list[tuple[str, str]]:
    """(name, description) for each mission skill in the engine's skills dir.

    Frontmatter is parsed with plain line scanning (stdlib only); a skill
    whose frontmatter is unreadable still shows up by directory name so the
    builder knows it exists."""
    skills: list[tuple[str, str]] = []
    for skill_md in sorted(skills_root(engine).glob("*/SKILL.md")):
        name, description = skill_md.parent.name, ""
        try:
            text = skill_md.read_text(encoding="utf-8", errors="replace")
        except OSError:
            text = ""
        lines = text.splitlines()
        if lines and lines[0].strip() == "---":
            for index, line in enumerate(lines[1:], start=1):
                if line.strip() == "---":
                    break
                if line.startswith("name:"):
                    name = line.split(":", 1)[1].strip().strip("'\"") or name
                elif line.startswith("description:"):
                    value = line.split(":", 1)[1].strip()
                    if value in ("|", "|-", ">", ">-"):
                        # YAML block scalar: the first indented line carries
                        # the summary sentence — enough for the prompt listing.
                        for follow in lines[index + 1:]:
                            if follow.strip():
                                value = follow.strip()
                                break
                    description = value.strip("'\"").replace('\\"', '"')
        if len(description) > 400:
            description = description[:400].rstrip() + " …"
        skills.append((name, description))
    return skills


def build_skills_block(state: State, engine: str) -> str:
    """The iteration prompt's skills section: what exists, and — pushier as
    failures repeat — when to grow the toolbox with skill-creator. Repeated
    failure is the loop's clearest signal that a capability is missing rather
    than a strategy being wrong, so the nudge escalates with the ladder."""
    rel = ENGINE_SKILL_DIRS.get(engine, ".claude/skills")
    skills = list_skills(engine)
    if skills:
        listing = "\n".join(
            f"- `{name}` — {description}" if description else f"- `{name}`"
            for name, description in skills)
        block = (
            f"\n## Mission skills (reusable capabilities in {rel}/)\n\n"
            f"{listing}\n\n"
            "Apply any skill that fits before working from scratch — read its "
            f"SKILL.md at {rel}/<name>/SKILL.md first (skills bundle scripts "
            "and reference files there too; load only what the task needs). "
            "When you notice recurring complexity (a procedure done twice, a "
            "helper rewritten, knowledge worth keeping), use `skill-creator` "
            "to create or enhance a skill, then use it. Skills persist across "
            "iterations; they are how this loop compounds learning.\n"
        )
    else:
        block = (
            f"\n## Mission skills (reusable capabilities in {rel}/)\n\n"
            "None yet. When you notice recurring complexity worth codifying, "
            f"create a skill at {rel}/<name>/SKILL.md so later "
            "iterations inherit the capability instead of re-deriving it.\n"
        )
    if state.repeated_failure_count >= 1:
        block += (
            "\nThe same failure has repeated — before retrying, ask whether it "
            "traces to a missing or under-specified capability. If so, spend "
            "part of this iteration codifying the fix as a skill (or repairing "
            "the skill that misled you) so the failure cannot recur.\n"
        )
    return block


def build_iteration_prompt(
    runtime: dict[str, Any],
    state: State,
    engine: str,
) -> str:
    previous_work = "This is the first iteration — start from the mission goal."
    if state.latest_agent_result:
        structured = agent_structured(ROOT / state.latest_agent_result)
        if structured:
            previous_work = (
                "Where the previous iteration left off (its own report):\n"
                + json.dumps(structured, indent=2)[:12000]
            )

    critic_block = ""
    if state.latest_critic_findings:
        findings_file = ROOT / state.latest_critic_findings
        if findings_file.is_file():
            findings = findings_file.read_text(encoding="utf-8", errors="replace")[-4000:]
            critic_block = f"\n## Blocking critic findings to repair\n\n{findings}\n"

    feedback_block = ""
    if state.human_feedback:
        feedback_block = (
            "\n## Operator feedback (address this first)\n\n"
            f"{state.human_feedback.strip()}\n"
        )

    min_iter = int(runtime.get("min_iterations", 1) or 1)
    min_iter_block = ""
    if state.iteration < min_iter:
        min_iter_block = (
            f"\nMinimum iterations: a \"done\": true report will NOT be accepted "
            f"before iteration {min_iter}. Use this iteration to find the weakest "
            "part of the current result and demonstrably improve it — do not "
            "spend it re-confirming that existing work is fine.\n"
        )

    skills_block = build_skills_block(state, engine)

    rung = thinking_rung(runtime, state)
    posture = str(rung.get("posture", "")).strip()
    if engine == "claude":
        # The keyword is claude's extended-thinking trigger; leading position
        # makes it unmissable. The matching MAX_THINKING_TOKENS budget is
        # exported to the CLI by the loop, so the depth is real, not rhetorical.
        keyword = rung["claude_keyword"]
        thinking_block = (
            f"{keyword}: {posture}\n\n"
            f"Thinking depth for this iteration: {keyword} "
            f"({rung.get('claude_thinking_tokens', '?')} thinking tokens, escalated "
            f"from {state.repeated_failure_count} repeated failure(s))."
        )
    elif engine == "grok":
        thinking_block = (
            f"Reasoning posture for this iteration (budget scale "
            f"×{float(rung.get('budget_scale', 1.0)):g}, escalated from "
            f"{state.repeated_failure_count} repeated failure(s)): {posture}"
        )
    else:
        thinking_block = (
            f"Reasoning posture for this iteration ({rung['codex_effort']} effort, "
            f"escalated from {state.repeated_failure_count} repeated failure(s)): "
            f"{posture}"
        )

    native_block = delegation_posture(engine)
    native_section = f"\n{native_block}\n" if native_block else ""

    return f"""# ABSOLOOP bounded repair iteration

{thinking_block}
{native_section}
## Mission goal contract (ground truth — overrides any other narrative)

{load_goal(runtime).strip()}

## Loop position

Iteration: {state.iteration} of {runtime['max_iterations']} \
({runtime['max_iterations'] - state.iteration} remaining)
Repeated failure count: {state.repeated_failure_count}
{min_iter_block}
## Where the mission stands

{previous_work}
{critic_block}{feedback_block}{skills_block}
## Required procedure

1. Read the project instructions and the goal contract above.
2. Inspect the current state of the working tree before editing.
3. Check the mission skills listed above; apply any that fit this
   iteration's work before solving from scratch.
4. Choose one bounded strategy from the goal contract's strategy ladder that
   differs from any failed repeated strategy.
5. If this iteration is a multi-file / multi-component / larger build: spawn
   your agent team first (see Builder role above), then coordinate. Stay
   mission-scoped — no opportunistic edits outside the contract — but do not
   interpret "scoped" as "work alone." Solo only true one-file fixes.
   When work reveals recurring complexity, codify it with `skill-creator`.
6. Run a focused check when available (tests, a build, the program itself)
   and record what you ran and what it showed.
7. Never weaken tests or acceptance criteria.
8. Return schema-valid JSON with changed artifacts, commands, evidence, risks,
   and a concise decision summary. Mention teammates you spawned (names/roles)
   in the summary when you used a team. Set "done": true ONLY when every item
   in the definition of done is genuinely met — an independent critic will
   inspect the working tree and reject unearned claims. Otherwise set
   "done": false and say what remains.

Do not push, publish, deploy, or perform destructive/external actions —
delivery is handled by the loop after acceptance, per the goal contract.
"""


def run_claude(prompt: str, cfg: dict[str, Any], out_path: pathlib.Path,
               json_schema: dict[str, Any] | None = None,
               label: str = "claude agent",
               extra_env: dict[str, str] | None = None,
               model: str = "") -> AgentRun:
    schema = json.dumps(json_schema) if json_schema else RESULT_SCHEMA.read_text(encoding="utf-8")
    command = [
        # shutil.which resolves claude.cmd/.exe on Windows (PATHEXT), where a
        # bare name in argv-list form would not be found.
        shutil.which("claude") or "claude",
        "-p",
        "--permission-mode", cfg["permission_mode"],
        "--max-turns", str(cfg["max_turns"]),
        "--max-budget-usd", str(cfg["max_budget_usd"]),
        "--json-schema", schema,
        # stream-json narrates the run live (tool calls, agent messages) while
        # still delivering the same final result payload as a terminal event.
        "--output-format", "stream-json",
        "--verbose",
        # Headless Builder runs: keep Agent Teams in-process (no tmux panes).
        "--teammate-mode", "in-process",
    ]
    if model:
        command += ["--model", model]
    command.append(prompt)
    say(f"{label}: starting (limits: {cfg['max_turns']} turns, "
        f"${cfg['max_budget_usd']}, {cfg.get('max_wall_seconds', 600)}s wall"
        + (f", model={model}" if model else "") + ")")
    started = time.time()
    result_event: dict[str, Any] = {}

    def on_line(line: str) -> None:
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            return
        if isinstance(event, dict) and event.get("type") == "result":
            result_event.update(event)
            return
        narrate(label, claude_stream_events(line))

    # --max-turns bounds turns, not wall time; a single exploratory turn can run
    # for minutes, so every agent run also gets a hard wall-clock bound.
    with heartbeat(label):
        exit_code, timed_out, stdout, stderr = stream_process(
            command, float(cfg.get("max_wall_seconds", 600)), on_line,
            env={**os.environ, **(extra_env or {})})
    out_path.with_suffix(".stream.jsonl").write_text(stdout, encoding="utf-8")
    if timed_out:
        out_path.write_text(json.dumps(result_event) if result_event else "",
                            encoding="utf-8")
        out_path.with_suffix(".stderr.log").write_text(
            stderr + "\nAGENT_WALL_TIMEOUT\n", encoding="utf-8")
        run = AgentRun(124, float(cfg["max_budget_usd"]), False, "wall_timeout", out_path)
        say(f"{label}: KILLED at {cfg.get('max_wall_seconds', 600)}s wall-clock limit", "err")
        append_ledger({"type": "agent_run", "engine": "claude", "exit_code": 124,
                       "wall_seconds": time.time() - started, "cost_usd": run.cost_usd,
                       "cost_is_exact": False, "limit_reached": "wall_timeout",
                       "result": str(out_path.relative_to(ROOT))})
        return run
    # The final result event carries exact total_cost_usd, and an error subtype
    # such as error_max_turns or error_max_budget_usd when a limit ended the run.
    # Persist it as the run's result payload; if the stream ended without one
    # (crash, unexpected CLI output), fall back to raw stdout so nothing that
    # was said is lost, and downstream parsing treats the run as not-done.
    payload: dict[str, Any] | None = result_event or None
    if payload is not None:
        out_path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
    else:
        out_path.write_text(stdout, encoding="utf-8")
        say(f"{label}: stream ended without a result event — treating the run "
            f"as unfinished (raw stream: {out_path.with_suffix('.stream.jsonl').relative_to(ROOT)})",
            "warn")
    out_path.with_suffix(".stderr.log").write_text(stderr, encoding="utf-8")

    exact = payload.get("total_cost_usd") if payload else None
    cost_is_exact = isinstance(exact, (int, float))
    subtype = str(payload.get("subtype", "")) if payload else ""
    limit = subtype if payload and payload.get("is_error") and subtype.startswith("error_") else None
    usage = payload.get("usage") if payload else None
    tokens = None
    if isinstance(usage, dict):
        counted = [int(usage[key]) for key in
                   ("input_tokens", "cache_creation_input_tokens",
                    "cache_read_input_tokens", "output_tokens")
                   if isinstance(usage.get(key), (int, float))]
        tokens = sum(counted) if counted else None

    run = AgentRun(
        exit_code=exit_code,
        cost_usd=float(exact) if cost_is_exact else float(cfg["max_budget_usd"]),
        cost_is_exact=cost_is_exact,
        limit_reached=limit,
        output_path=out_path,
        tokens=tokens,
    )
    outcome = "finished" if run.exit_code == 0 and not run.limit_reached else "FAILED"
    detail = f" — cut off by limit '{run.limit_reached}'" if run.limit_reached else ""
    turns = payload.get("num_turns") if payload else None
    say(f"{label}: {outcome} in {time.time() - started:.0f}s, "
        f"cost ${run.cost_usd:.2f}"
        + (f" ({fmt_tokens(run.tokens)})" if fmt_tokens(run.tokens) else "")
        + (f", {turns} turn(s)" if isinstance(turns, int) else "")
        + detail,
        "ok" if outcome == "finished" else "err")
    if run.limit_reached in ("error_max_budget_usd", "error_max_turns"):
        say(f"{label}: hint — the run was terminated by its own budget before it "
            "could finish; consider raising claude.builder limits in .absoloop/runtime.json")
    append_ledger({
        "type": "agent_run",
        "engine": "claude",
        "exit_code": run.exit_code,
        "wall_seconds": time.time() - started,
        "cost_usd": run.cost_usd,
        "cost_is_exact": run.cost_is_exact,
        "tokens": run.tokens,
        "limit_reached": run.limit_reached,
        "result": str(out_path.relative_to(ROOT)),
    })
    return run


def codex_usage_totals(events_path: pathlib.Path) -> dict[str, int] | None:
    """Summed token usage from turn.completed events, None when none appeared."""
    totals = {"input_tokens": 0, "cached_input_tokens": 0, "output_tokens": 0}
    seen = False
    try:
        lines = events_path.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        return None
    for line in lines:
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        usage = event.get("usage") if event.get("type") == "turn.completed" else None
        if isinstance(usage, dict):
            seen = True
            for key in totals:
                value = usage.get(key)
                if isinstance(value, (int, float)):
                    totals[key] += int(value)
    return totals if seen else None


def codex_usage_to_usd(totals: dict[str, int] | None,
                       pricing: dict[str, float] | None) -> float | None:
    """Convert summed token usage to dollars with the configured rates."""
    if not totals or not pricing:
        return None
    fresh_input = max(0, totals["input_tokens"] - totals["cached_input_tokens"])
    return (
        fresh_input * pricing["input_per_mtok_usd"]
        + totals["cached_input_tokens"] * pricing["cached_input_per_mtok_usd"]
        + totals["output_tokens"] * pricing["output_per_mtok_usd"]
    ) / 1_000_000


def run_codex(prompt: str, cfg: dict[str, Any], pricing: dict[str, float] | None,
              out_path: pathlib.Path, schema_path: pathlib.Path,
              label: str = "codex agent",
              model: str = "") -> AgentRun:
    # codex exec is non-interactive and never prompts; the sandbox policy is
    # the enforcement boundary for scripted runs. Codex has no per-run dollar
    # cap flag, so max_budget_usd is the accounting reserve when parsing fails.
    #
    # Always pass an OpenAI-strict copy: missions scaffolded before the
    # additionalProperties fix still have a loose agent-result.schema.json on
    # disk, and Codex 400s those with invalid_json_schema / codex_output_schema.
    try:
        raw_schema = json.loads(schema_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        say(f"{label}: unreadable output schema {schema_path}: {exc}", "err")
        return AgentRun(2, float(cfg.get("max_budget_usd", 5.0)), False,
                        "schema_error", out_path)
    if not isinstance(raw_schema, dict):
        say(f"{label}: output schema root must be a JSON object", "err")
        return AgentRun(2, float(cfg.get("max_budget_usd", 5.0)), False,
                        "schema_error", out_path)
    strict_schema = openai_strict_json_schema(raw_schema)
    strict_path = out_path.with_suffix(".output.schema.json")
    strict_path.write_text(json.dumps(strict_schema, indent=2) + "\n",
                           encoding="utf-8")

    effort = str(cfg.get("model_reasoning_effort", "") or "")
    command = [
        shutil.which("codex") or "codex", "exec",
        "--sandbox", cfg["sandbox"],
        "--output-schema", str(strict_path),
        "--json",
        "-o", str(out_path),
    ]
    if model:
        command += ["--model", model]
    if effort:
        command += ["-c", f"model_reasoning_effort={effort}"]
    command.append(prompt)
    say(f"{label}: starting (limits: sandbox={cfg['sandbox']}, "
        f"{cfg.get('max_wall_seconds', 600)}s wall"
        + (f", model={model}" if model else "")
        + (f", reasoning={effort}" if effort else "") + ")")
    started = time.time()
    events_path = out_path.with_suffix(".events.jsonl")

    def on_line(line: str) -> None:
        narrate(label, codex_stream_events(line))

    with heartbeat(label):
        exit_code, timed_out, stdout, stderr = stream_process(
            command, float(cfg.get("max_wall_seconds", 600)), on_line)
    events_path.write_text(stdout, encoding="utf-8")
    if timed_out:
        out_path.with_suffix(".stderr.log").write_text(
            stderr + "\nAGENT_WALL_TIMEOUT\n", encoding="utf-8")
        run = AgentRun(124, float(cfg["max_budget_usd"]), False, "wall_timeout", out_path)
        say(f"{label}: KILLED at {cfg.get('max_wall_seconds', 600)}s wall-clock limit", "err")
        append_ledger({"type": "agent_run", "engine": "codex", "exit_code": 124,
                       "wall_seconds": time.time() - started, "cost_usd": run.cost_usd,
                       "cost_is_exact": False, "limit_reached": "wall_timeout",
                       "result": str(out_path.relative_to(ROOT))})
        return run
    out_path.with_suffix(".stderr.log").write_text(stderr, encoding="utf-8")

    totals = codex_usage_totals(events_path)
    exact = codex_usage_to_usd(totals, pricing)
    tokens = (totals["input_tokens"] + totals["output_tokens"]) if totals else None
    run = AgentRun(
        exit_code=exit_code,
        cost_usd=exact if exact is not None else float(cfg["max_budget_usd"]),
        cost_is_exact=exact is not None,
        limit_reached=None,
        output_path=out_path,
        tokens=tokens,
    )
    say(f"{label}: {'finished' if run.exit_code == 0 else 'FAILED'} in "
        f"{time.time() - started:.0f}s, cost ${run.cost_usd:.2f}"
        + (f" ({fmt_tokens(run.tokens)})" if fmt_tokens(run.tokens) else "")
        + f"{'' if run.cost_is_exact else ' (estimated)'}",
        "ok" if run.exit_code == 0 else "err")
    append_ledger({
        "type": "agent_run",
        "engine": "codex",
        "exit_code": run.exit_code,
        "wall_seconds": time.time() - started,
        "cost_usd": run.cost_usd,
        "cost_is_exact": run.cost_is_exact,
        "tokens": run.tokens,
        "result": str(out_path.relative_to(ROOT)),
        "events": str(events_path.relative_to(ROOT)),
    })
    return run


def grok_permission_flags(profile: str) -> list[str]:
    """Map Absoloop permission profiles to Grok Build CLI flags (fail closed)."""
    if profile == "read":
        return ["--tools", "read_file,grep,list_dir,glob"]
    if profile == "edit":
        return ["--allow", "Edit", "--allow", "Write", "--allow", "Read",
                "--allow", "Grep", "--allow", "Bash",
                "--deny", "Bash(sudo*)", "--deny", "Bash(rm -rf /*)"]
    if profile == "full":
        return ["--yolo"]
    return grok_permission_flags("edit")


def _extract_json_object(text: str) -> dict[str, Any] | None:
    """Best-effort: last JSON object in a blob (Grok has no --json-schema)."""
    decoder = json.JSONDecoder()
    last: dict[str, Any] | None = None
    index = 0
    while index < len(text):
        start = text.find("{", index)
        if start < 0:
            break
        try:
            value, end = decoder.raw_decode(text, start)
        except json.JSONDecodeError:
            index = start + 1
            continue
        if isinstance(value, dict):
            last = value
        index = end
    return last


def run_grok(prompt: str, cfg: dict[str, Any], out_path: pathlib.Path,
             schema: dict[str, Any] | None = None,
             label: str = "grok agent",
             model: str = "") -> AgentRun:
    """Spawn Grok Build headless (streaming-json + --prompt-file)."""
    profile = str(cfg.get("permission_profile") or "edit")
    schema = schema or json.loads(RESULT_SCHEMA.read_text(encoding="utf-8"))
    schema_path = out_path.with_suffix(".schema.json")
    schema_path.write_text(json.dumps(schema, indent=2) + "\n", encoding="utf-8")
    result_instruction = (
        f"\n\n## Absoloop structured result (required)\n"
        f"When finished, write a single JSON object that validates against the "
        f"schema at `{schema_path}` to `{out_path}`. The JSON must be the only "
        f"contents of that file. Also print the same JSON object as your final "
        f"message so the loop can recover it if the file write fails.\n"
    )
    prompt_path = out_path.with_suffix(".prompt.md")
    prompt_path.write_text(prompt.rstrip() + result_instruction, encoding="utf-8")
    command = [
        shutil.which("grok") or "grok",
        "--prompt-file", str(prompt_path),
        "--output-format", "streaming-json",
        "--cwd", str(ROOT),
        "--no-auto-update",
    ]
    if model:
        command += ["-m", model]
    max_turns = cfg.get("max_turns")
    if isinstance(max_turns, int) and max_turns > 0:
        command += ["--max-turns", str(max_turns)]
    command += grok_permission_flags(profile)
    say(f"{label}: starting (limits: profile={profile}, "
        f"{cfg.get('max_wall_seconds', 600)}s wall"
        + (f", model={model}" if model else "")
        + (f", {max_turns} turns" if isinstance(max_turns, int) else "") + ")")
    started = time.time()
    stream_path = out_path.with_suffix(".stream.jsonl")
    text_chunks: list[str] = []
    usage: dict[str, Any] = {}
    cost_box: list[float | None] = [None]

    def on_line(line: str) -> None:
        narrate(label, grok_stream_events(line))
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            return
        if not isinstance(event, dict):
            return
        if event.get("type") == "text":
            text_chunks.append(str(event.get("data", "")))
        elif event.get("type") == "end":
            if isinstance(event.get("usage"), dict):
                usage.update(event["usage"])
            cost = event.get("total_cost_usd")
            if isinstance(cost, (int, float)):
                cost_box[0] = float(cost)
            elif isinstance(usage.get("cost_usd"), (int, float)):
                cost_box[0] = float(usage["cost_usd"])

    with heartbeat(label):
        exit_code, timed_out, stdout, stderr = stream_process(
            command, float(cfg.get("max_wall_seconds", 600)), on_line)
    stream_path.write_text(stdout, encoding="utf-8")
    end_cost = cost_box[0]
    if timed_out:
        out_path.with_suffix(".stderr.log").write_text(
            stderr + "\nAGENT_WALL_TIMEOUT\n", encoding="utf-8")
        run = AgentRun(124, float(cfg["max_budget_usd"]), False, "wall_timeout", out_path)
        say(f"{label}: KILLED at {cfg.get('max_wall_seconds', 600)}s wall-clock limit", "err")
        append_ledger({"type": "agent_run", "engine": "grok", "exit_code": 124,
                       "wall_seconds": time.time() - started, "cost_usd": run.cost_usd,
                       "cost_is_exact": False, "limit_reached": "wall_timeout",
                       "result": str(out_path.relative_to(ROOT))})
        return run
    out_path.with_suffix(".stderr.log").write_text(stderr, encoding="utf-8")

    # Prefer a file the agent wrote; fall back to JSON embedded in streamed text.
    structured: dict[str, Any] | None = None
    if out_path.is_file():
        try:
            candidate = json.loads(out_path.read_text(encoding="utf-8"))
            if isinstance(candidate, dict):
                structured = candidate
        except (OSError, json.JSONDecodeError):
            structured = None
    if structured is None:
        structured = _extract_json_object("".join(text_chunks)) or _extract_json_object(stdout)
        if structured is not None:
            out_path.write_text(json.dumps(structured, indent=2) + "\n", encoding="utf-8")
    if structured is None:
        out_path.write_text(json.dumps({
            "done": False,
            "summary": "grok produced no schema-valid JSON result",
            "changed_artifacts": [],
            "commands_run": [],
            "evidence": [],
            "risks": ["unreadable structured result"],
        }, indent=2) + "\n", encoding="utf-8")
        say(f"{label}: stream ended without schema-valid JSON — treating as unfinished",
            "warn")

    tokens = None
    if usage:
        counted = [int(usage[key]) for key in
                   ("input_tokens", "output_tokens", "total_tokens")
                   if isinstance(usage.get(key), (int, float))]
        if counted:
            tokens = sum(counted) if "total_tokens" not in usage else int(usage["total_tokens"])

    cost_is_exact = isinstance(end_cost, float)
    run = AgentRun(
        exit_code=exit_code,
        cost_usd=float(end_cost) if cost_is_exact else float(cfg["max_budget_usd"]),
        cost_is_exact=cost_is_exact,
        limit_reached=None,
        output_path=out_path,
        tokens=tokens,
    )
    say(f"{label}: {'finished' if run.exit_code == 0 else 'FAILED'} in "
        f"{time.time() - started:.0f}s, cost ${run.cost_usd:.2f}"
        + (f" ({fmt_tokens(run.tokens)})" if fmt_tokens(run.tokens) else "")
        + f"{'' if run.cost_is_exact else ' (estimated)'}",
        "ok" if run.exit_code == 0 else "err")
    append_ledger({
        "type": "agent_run",
        "engine": "grok",
        "exit_code": run.exit_code,
        "wall_seconds": time.time() - started,
        "cost_usd": run.cost_usd,
        "cost_is_exact": run.cost_is_exact,
        "tokens": run.tokens,
        "result": str(out_path.relative_to(ROOT)),
        "events": str(stream_path.relative_to(ROOT)),
    })
    return run


def mission_model(runtime: dict[str, Any], override: str = "",
                  engine: str = "") -> str:
    """Model id/alias for this mission — CLI override wins, else runtime.json.

    When ``engine`` is set, remap curated aliases that belong to another
    engine (Claude ``best`` is not valid for Codex ChatGPT auth).
    """
    requested = (override or str(runtime.get("model") or "")).strip()
    if not engine:
        return requested
    try:
        from absoloop_harness.models import resolve_model
    except ImportError:
        # Project runners may not have the harness package on sys.path;
        # fall back to a minimal remap for the known Claude → Codex case.
        if engine == "codex" and requested in {
                "best", "fable", "opus", "sonnet", "haiku"}:
            return "gpt-5.6-sol"
        if engine == "claude" and requested.startswith("gpt-5.6-"):
            return "best"
        return requested or ({
            "claude": "best",
            "codex": "gpt-5.6-sol",
            "grok": "grok-build-0.1",
        }.get(engine, ""))
    return resolve_model(engine, requested)


def run_critic(engine: str, runtime: dict[str, Any], state: State,
               model: str = "") -> tuple[dict[str, Any] | None, AgentRun]:
    """Independent read-only review. The critic sees the contract, never the
    builder's narrative — it must gather its own evidence from the tree."""
    prompt_path = ROOT / runtime["critic_prompt_path"]
    base = prompt_path.read_text(encoding="utf-8") if prompt_path.is_file() else (
        "You are an independent adversarial reviewer. Attempt to disprove that the\n"
        "current working tree satisfies the mission contract. Do not edit files."
    )
    prompt = (
        f"{base}\n\n"
        "Mission goal contract (ground truth — includes any extension "
        "requirements and continuation intent, all of which are binding):\n\n"
        f"{load_goal(runtime).strip()}\n\n"
        f"Definition of done: {json.dumps(runtime['definition_of_done'], indent=2)}\n\n"
        "The builder claims the mission is done. Inspect the working tree "
        "yourself and run read-only checks (tests, builds, the program) to "
        "confirm or refute that claim; do not trust any builder narrative.\n"
        "Return JSON with recommendation (PASS, HOLD, or REJECT), blocking_findings, and summary."
    )

    out_path = TMP / f"iteration-{state.iteration:04d}-critic.json"
    MONITOR.update(phase="critic review", agent="critic", agent_started=time.time())
    verdict: dict[str, Any] | None = None
    if engine == "claude":
        run = run_claude(prompt, runtime["claude"]["critic"], out_path,
                         json_schema=CRITIC_SCHEMA, label="critic", model=model)
        try:
            payload = json.loads(out_path.read_text(encoding="utf-8"))
            candidate = payload.get("structured_output") if isinstance(payload, dict) else None
        except (OSError, json.JSONDecodeError):
            candidate = None
    elif engine == "grok":
        run = run_grok(prompt, runtime["grok"]["critic"], out_path,
                       schema=CRITIC_SCHEMA, label="critic", model=model)
        try:
            candidate = json.loads(out_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            candidate = None
    else:
        schema_path = TMP / "critic-schema.json"
        atomic_write_json(schema_path, CRITIC_SCHEMA)
        run = run_codex(prompt, runtime["codex"]["critic"], runtime["codex"].get("pricing"),
                        out_path, schema_path, label="critic", model=model)
        try:
            candidate = json.loads(out_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            candidate = None

    if isinstance(candidate, dict) and candidate.get("recommendation") in {"PASS", "HOLD", "REJECT"}:
        verdict = candidate
        style = {"PASS": "ok", "HOLD": "warn", "REJECT": "err"}[verdict["recommendation"]]
        say(f"critic verdict: {verdict['recommendation']} — {verdict.get('summary', '')[:200]}", style)
        findings, more = _clean_list(verdict.get("blocking_findings"), 6)
        for finding in findings:
            say(f"critic blocking finding: {finding}", "warn")
        if more:
            say(f"critic recorded {more} more blocking finding(s)", "warn")
        MONITOR.activity("critic", "verdict",
                         f"{verdict['recommendation']}: {verdict.get('summary', '')}")
    else:
        say("critic verdict: UNREADABLE (treated as an error, not a pass)", "err")
        MONITOR.activity("critic", "verdict", "UNREADABLE (treated as an error)")
    return verdict, run


def final_acceptance(runtime: dict[str, Any], state: State, engine: str,
                     check_timeout: int,
                     model: str = "") -> tuple[str, str] | None:
    """Layered acceptance — the non-negotiable gate sequence.

    Order is fixed: integrity → critic → human gate. Returns
    ``(stop_reason, terminal_status)`` when the mission should stop, or
    ``None`` when the repair loop should continue (e.g. critic HOLD).
    """
    state.status = "FINAL_REVIEW"
    say("builder reports done — entering final acceptance (integrity, critic)", "bold")
    MONITOR.update(phase="final acceptance", status="FINAL_REVIEW")

    # --- 1. Integrity (optional command; fail closed on non-zero) ----------
    integrity_command = runtime.get("integrity_command")
    if integrity_command:
        MONITOR.update(phase="integrity check")
        integrity_log = TMP / f"iteration-{state.iteration:04d}-integrity.log"
        integrity = run_command(integrity_command, integrity_log, check_timeout)
        append_ledger({"type": "integrity_check", "iteration": state.iteration,
                       "exit_code": integrity.returncode})
        if integrity.returncode != 0:
            # Weakened tests or edited checks are an automatic failure (14.3).
            return "integrity_violation", "REJECTED"

    # --- 2. Independent critic (PASS / HOLD / REJECT; unreadable → ERROR) --
    verdict, run = run_critic(engine, runtime, state, model=model)
    state.cost_usd += run.cost_usd
    state.tokens_total += run.tokens or 0
    if not run.cost_is_exact:
        state.inexact_cost_events += 1
    report_spend(state, runtime)
    if verdict is None:
        # An unreadable critic is ERROR, not PASS (Section 14.5).
        return "critic_unavailable", "BLOCKED"

    if verdict["recommendation"] == "REJECT":
        return "critic_reject", "REJECTED"

    if verdict["recommendation"] == "HOLD":
        findings_path = TMP / f"iteration-{state.iteration:04d}-critic-findings.json"
        atomic_write_json(findings_path, verdict)
        state.latest_critic_findings = str(findings_path.relative_to(ROOT))
        fingerprint = normalized_fingerprint(
            "critic:" + "\n".join(str(f) for f in verdict["blocking_findings"])
        )
        if fingerprint == state.last_failure_fingerprint:
            state.repeated_failure_count += 1
        else:
            state.repeated_failure_count = 1
            state.last_failure_fingerprint = fingerprint
        if state.repeated_failure_count >= int(runtime["no_progress_window"]):
            return "critic_findings_not_converging", "BLOCKED"
        return None  # findings feed the next repair iteration

    # --- 3. Human gate (default on; delivery happens only after approve) ---
    state.latest_critic_findings = None
    if runtime.get("require_human_approval", True):
        # Externalization stays behind the human gate (Section 16).
        return "accepted_pending_human_gate", "AWAITING_APPROVAL"
    return "accepted_by_all_gates", "COMPLETED"


# ---------------------------------------------------------------------------
# Results: report.md after every stop, delivery after acceptance.
# ---------------------------------------------------------------------------

def git_changed_files() -> list[str]:
    """Paths with uncommitted changes (staged, unstaged, or untracked)."""
    if not shutil.which("git"):
        return []
    # -uall lists each untracked file individually instead of collapsing new
    # directories to 'dir/', which the copy step could not resolve to files.
    result = subprocess.run(["git", "status", "--porcelain", "-uall"], cwd=ROOT,
                            text=True, capture_output=True, check=False)
    if result.returncode != 0:
        return []
    paths: list[str] = []
    for line in result.stdout.splitlines():
        if len(line) < 4:
            continue
        path = line[3:].strip().strip('"')
        if " -> " in path:  # renames: keep the destination
            path = path.split(" -> ", 1)[1].strip('"')
        paths.append(path)
    return sorted(set(paths))


def archive_report(runtime: dict[str, Any], state: State) -> pathlib.Path | None:
    """Persist report.md (+ html if present) under ``.absoloop/reports/<loop>/``.

    Also mirrors into ``.absoloop/runs/<loop>/`` so extend archives and ZComb
    search share the same history. Stdlib-only — no harness import.
    """
    md = ABS / "report.md"
    html = ABS / "report.html"
    if not md.is_file() and not html.is_file():
        return None
    loop_id = str(runtime.get("loop_id") or state.mission_id or "loop").strip()
    dest = ABS / "reports" / loop_id
    dest.mkdir(parents=True, exist_ok=True)
    for src in (md, html):
        if src.is_file():
            shutil.copy2(src, dest / src.name)
    meta = {
        "loopId": loop_id,
        "missionId": state.mission_id,
        "status": state.status,
        "stopReason": state.stop_reason,
        "iteration": state.iteration,
        "costUsd": state.cost_usd,
        "objective": str(runtime.get("objective") or "")[:500],
        "archivedAt": time.time(),
        "hasMarkdown": (dest / "report.md").is_file(),
        "hasHtml": (dest / "report.html").is_file(),
    }
    try:
        (dest / "meta.json").write_text(
            json.dumps(meta, indent=2) + "\n", encoding="utf-8")
    except OSError:
        pass
    run_dest = ABS / "runs" / loop_id
    try:
        run_dest.mkdir(parents=True, exist_ok=True)
        for name in ("report.md", "report.html"):
            src = dest / name
            if src.is_file():
                shutil.copy2(src, run_dest / name)
        # Keep a state snapshot alongside the report for past-loop cards.
        if STATE_PATH.is_file():
            shutil.copy2(STATE_PATH, run_dest / "state.json")
    except OSError:
        pass
    return dest


def write_report(runtime: dict[str, Any], state: State) -> pathlib.Path:
    """Human-readable mission report Markdown, regenerated at every stop.

    Structure matches the infographic document that `absoloop report` regenerates
    and opens in the lite HTML viewer. The runner stays stdlib-standalone, so
    this writes Markdown only; the CLI adds the viewer on demand.
    Archives a copy under ``.absoloop/reports/<loop_id>/`` after writing.
    """
    report_path = ABS / "report.md"
    changed = [p for p in git_changed_files() if not p.startswith(".absoloop/")]
    delivery = runtime.get("delivery") or {"mode": "local"}
    mode = delivery.get("mode", "local")
    if mode == "git":
        delivery_detail = delivery.get("branch") or "absoloop/<loop>"
    elif mode == "out":
        delivery_detail = str(delivery.get("out_dir") or "~/absoloop/out/<loop>")
    else:
        delivery_detail = "working tree (unstaged)"
    tokens_note = fmt_tokens(state.tokens_total)
    gen = time.strftime("%Y-%m-%d %H:%M", time.localtime())
    max_iter = runtime.get("max_iterations", "?")
    max_cost = float(runtime.get("max_cost_usd", 0))
    lines = [
        "# Absoloop Report",
        "",
        f"**{state.status}** · `{state.mission_id}` · loop `{runtime.get('loop_id', '—')}`",
        "",
        f"> Generated {gen}",
        "",
        "---",
        "",
        "## Mission",
        "",
        (runtime.get("objective") or "_(no objective recorded)_").strip(),
        "",
        "| | |",
        "|---|---|",
        f"| **Engine** | `{runtime.get('engine') or runtime.get('builder') or '—'}` |",
        f"| **Delivery** | `{mode}` → {delivery_detail} |",
        f"| **Status** | **{state.status}**"
        + (f" ({state.stop_reason})" if state.stop_reason else "")
        + " |",
        "",
        "---",
        "",
        "## At a glance",
        "",
        "| Metric | Used | Budget |",
        "|---|---:|---:|",
        f"| Iterations | {state.iteration} | {max_iter} |",
        f"| Spend | ${state.cost_usd:.2f}"
        + (f" ({tokens_note})" if tokens_note else "")
        + f" | ${max_cost:.2f} |",
        "",
        "---",
        "",
        "## Run arc",
        "",
    ]
    try:
        ledger_lines = LEDGER_PATH.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        ledger_lines = []
    if not ledger_lines:
        lines.append("_No ledger events yet — the loop has not run._")
    for raw in ledger_lines:
        try:
            event = json.loads(raw)
        except json.JSONDecodeError:
            continue
        ts = time.strftime("%Y-%m-%d %H:%M", time.localtime(event.get("ts", 0)))
        kind = event.get("type")
        if kind == "iteration":
            outcome = "Builder reports DONE" if event.get("done") else "Still in progress"
            lines.append(f"- **{ts}** · **Iteration {event.get('iteration')}** — {outcome}")
        elif kind == "early_done_claim":
            lines.append(f"- **{ts}** · **Early done claim held** — iteration "
                         f"{event.get('iteration')} below floor ({event.get('min_iterations')})")
        elif kind == "agent_run":
            tok = fmt_tokens(event.get("tokens"))
            lines.append(
                f"- **{ts}** · **{event.get('engine')} run** — exit {event.get('exit_code')}, "
                f"${float(event.get('cost_usd', 0)):.2f}"
                + (f" ({tok})" if tok else "")
                + f", {float(event.get('wall_seconds', 0)):.0f}s"
            )
        elif kind == "integrity_check":
            mark = "Passed" if event.get("exit_code") == 0 else "Violation"
            lines.append(f"- **{ts}** · **Integrity check** — {mark}")
        elif kind == "human_gate":
            note = event.get("feedback") or event.get("note") or ""
            lines.append(f"- **{ts}** · **Human gate · {event.get('decision')}**"
                         + (f" — {note}" if note else ""))
        elif kind == "delivery":
            lines.append(f"- **{ts}** · **Delivered ({event.get('mode')})** — "
                         f"{event.get('detail', '')}")
        elif kind == "mission_stop":
            lines.append(f"- **{ts}** · **Stop · {event.get('status')}** — "
                         f"{event.get('reason')}")
        elif kind == "extension":
            note = event.get("note") or ""
            lines.append(f"- **{ts}** · **Mission extended** — "
                         f"{event.get('previous_loop_id')} → {event.get('loop_id')}"
                         + (f" — {note}" if note else ""))
    lines += ["", "---", "", "## Changed files", ""]
    lines += [f"- `{path}`" for path in changed] or ["_None detected (or clean tree)._"]
    lines += ["", "---", "", "## Pointers", ""]
    pointers = False
    for key, label in (("latest_agent_result", "Latest agent result"),
                       ("latest_critic_findings", "Latest critic findings")):
        value = getattr(state, key)
        if value:
            lines.append(f"- {label}: `{value}`")
            pointers = True
    if not pointers:
        lines.append("_No saved agent/critic artifacts yet._")
    lines += [
        "",
        "---",
        "",
        f"_Absoloop · `{state.mission_id}` — open with `absoloop report` for the lite viewer_",
        "",
    ]
    report_path.write_text("\n".join(lines), encoding="utf-8")
    archived = archive_report(runtime, state)
    if archived is not None:
        try:
            say(f"report archived: {archived.relative_to(ROOT)}", "dim")
        except ValueError:
            say(f"report archived: {archived}", "dim")
    return report_path


def deliver_results(runtime: dict[str, Any], state: State) -> bool:
    """Externalize accepted work per the mission's delivery mode.

    git   → commit everything to a dedicated branch
    local → leave the working tree as-is
    out   → copy changed files + report into ~/absoloop/out/<loop_id>/"""
    delivery = runtime.get("delivery") or {"mode": "local"}
    mode = delivery.get("mode", "local")
    loop_id = runtime.get("loop_id", state.mission_id)

    if mode == "local":
        say("delivery (local): changes stay unstaged in the working tree — "
            "review with 'git diff', commit when satisfied")
        append_ledger({"type": "delivery", "mode": "local",
                       "detail": "changes left unstaged in the working tree"})
        return True

    if mode == "git":
        if not shutil.which("git"):
            say("delivery (git) FAILED: git not found on PATH — changes remain unstaged")
            return False
        branch = delivery.get("branch") or f"absoloop/{loop_id}"
        for command in (["git", "checkout", "-B", branch],
                        ["git", "add", "-A"],
                        ["git", "commit", "-m",
                         f"absoloop {state.mission_id} {loop_id}: "
                         f"{runtime.get('objective', 'mission result')}"]):
            result = subprocess.run(command, cwd=ROOT, text=True,
                                    capture_output=True, check=False)
            if result.returncode != 0:
                tail = (result.stderr or result.stdout).strip().splitlines()[-1:] or ["unknown error"]
                say(f"delivery (git) FAILED at '{' '.join(command)}': {tail[0]}")
                return False
        say(f"delivery (git): committed to branch '{branch}' — push/PR when ready")
        append_ledger({"type": "delivery", "mode": "git", "detail": f"branch {branch}"})
        return True

    if mode == "out":
        out_dir = pathlib.Path(delivery.get("out_dir", "")
                               or pathlib.Path.home() / "absoloop" / "out" / loop_id).expanduser()
        files_dir = out_dir / "files"
        changed = [p for p in git_changed_files() if not p.startswith(".absoloop/")]
        copied = 0
        for rel in changed:
            src = ROOT / rel
            if not src.is_file():
                continue  # deletions and directories are recorded in the report
            dest = files_dir / rel
            dest.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(src, dest)
            copied += 1
        out_dir.mkdir(parents=True, exist_ok=True)
        report_path = write_report(runtime, state)
        shutil.copy2(report_path, out_dir / "report.md")
        for extra in (STATE_PATH, LEDGER_PATH):
            if extra.is_file():
                shutil.copy2(extra, out_dir / extra.name)
        goal_path = ROOT / runtime.get("goal_path", ".absoloop/goal.md")
        if goal_path.is_file():
            shutil.copy2(goal_path, out_dir / "goal.md")
        say(f"delivery (out): {copied} changed file(s) + report exported to {out_dir}")
        if not changed:
            say("delivery (out): note — no uncommitted changes were detected to copy")
        append_ledger({"type": "delivery", "mode": "out",
                       "detail": f"{copied} file(s) to {out_dir}"})
        return True

    say(f"delivery: unknown mode {mode!r} — changes remain unstaged")
    return False


def chime_mission(status: str, mission_id: str = "", detail: str = "") -> None:
    """Out-of-CLI chime + banner when the loop needs attention. Never raises."""
    home = os.environ.get("ABSOLOOP_HOME", "")
    if home and home not in sys.path:
        sys.path.insert(0, home)
    try:
        from absoloop_harness.notify import notify_mission
        notify_mission(status, mission_id=mission_id, detail=detail or None)
    except Exception:
        if status in ("AWAITING_APPROVAL", "COMPLETED", "BLOCKED", "REJECTED",
                      "BUDGET_EXHAUSTED"):
            try:
                sys.stdout.write("\a")
                sys.stdout.flush()
            except Exception:
                pass


def stop(state: State, reason: str, status: str, runtime: dict[str, Any]) -> int:
    state.stop_reason = reason
    state.status = status
    checkpoint(state, "terminal")
    append_ledger({"type": "mission_stop", "reason": reason, "status": status})
    MONITOR.update(phase="stopped", status=status, stop_reason=reason,
                   iteration=state.iteration, cost_usd=round(state.cost_usd, 4),
                   tokens_total=state.tokens_total, agent=None, ended_at=time.time())
    style = {"COMPLETED": "ok", "AWAITING_APPROVAL": "ok"}.get(status, "warn")
    tokens = f" ({fmt_tokens(state.tokens_total)})" if fmt_tokens(state.tokens_total) else ""
    say(f"mission stopped: {status} (reason: {reason}) after {state.iteration} "
        f"iteration(s), total cost ${state.cost_usd:.2f}{tokens}", style)
    if status == "COMPLETED":
        deliver_results(runtime, state)
    report_path = write_report(runtime, state)
    say(f"report: {report_path.relative_to(ROOT)} (or run 'absoloop report')")
    chime_mission(status, mission_id=state.mission_id,
                  detail=f"{reason} · {state.iteration} iteration(s)")
    if status == "COMPLETED":
        checkpoint(state, "terminal")  # persist any delivery bookkeeping
        return 0
    if status == "AWAITING_APPROVAL":
        # Every automated gate passed; human approval still required.
        say("next: review the diff, then 'absoloop approve' to "
            "accept, or 'absoloop reject \"what to change\"' to answer the agent "
            "and 'absoloop resume' to continue the loop")
        return 3
    return 2


def main() -> int:
    """Entry point for ``scripts/absoloop-run``.

    Normal path: load runtime/state, honor terminal-status guards, then iterate
    builder → (done? → final_acceptance). ``--deliver-only`` skips the loop and
    applies delivery (used by ``absoloop approve``).
    """
    parser = argparse.ArgumentParser()
    parser.add_argument("--engine", choices=["claude", "codex", "grok"])
    parser.add_argument("--model", default="",
                        help="model id/alias (overrides runtime.json model)")
    parser.add_argument("--deliver-only", action="store_true",
                        help="skip the loop: apply the mission's delivery mode to the "
                             "current results and regenerate the report (used by "
                             "'absoloop approve')")
    args = parser.parse_args()

    runtime = load_json(RUNTIME_PATH)
    model = mission_model(runtime, args.model, engine=args.engine or "")
    TMP.mkdir(parents=True, exist_ok=True)

    # Keep the live activity feed bounded: trim to its most recent tail when a
    # new run starts, so 'absoloop watch' stays fast on long-lived projects.
    try:
        if LIVE_PATH.is_file() and LIVE_PATH.stat().st_size > 1_000_000:
            tail = LIVE_PATH.read_text(encoding="utf-8", errors="replace").splitlines()[-1000:]
            LIVE_PATH.write_text("\n".join(tail) + "\n", encoding="utf-8")
    except OSError:
        pass

    if STATE_PATH.exists():
        state = State(**load_json(STATE_PATH))
    else:
        state = State(mission_id=runtime["mission_id"], started_at=time.time())
        checkpoint(state, "initial")

    if args.deliver_only:
        delivered = deliver_results(runtime, state)
        report_path = write_report(runtime, state)
        say(f"report: {report_path.relative_to(ROOT)} (or run 'absoloop report')")
        return 0 if delivered else 2

    if args.engine is None:
        parser.error("--engine is required unless --deliver-only is given")

    # Terminal-state guards: never burn budget re-running a decided mission.
    if state.status == "COMPLETED":
        say(f"mission {state.mission_id} is already COMPLETED — archive or delete "
            ".absoloop/state.json to start a new mission")
        return 0
    if state.status == "AWAITING_APPROVAL":
        say("mission passed every automated gate and is awaiting your decision — "
            "not re-running (that would spend budget on an accepted mission)")
        say("  accept:  absoloop approve")
        say('  respond: absoloop reject "what to change"   then: absoloop resume')
        return 3

    max_wall = float(runtime["max_wall_seconds"])
    check_timeout = min(900, int(max_wall))

    # One consolidated preparation block, then an explicit hand-off line —
    # everything after "/goal active" is real loop work, not setup noise.
    say(f"mission {state.mission_id}: {runtime['objective']}", "bold")
    say(f"  engine {args.engine}"
        + (f" · model {model}" if model else "")
        + f" · budgets {runtime['max_iterations']} iterations · "
        f"${runtime['max_cost_usd']:.2f} · {int(max_wall)}s wall clock", "dim")
    goal_path = ROOT / runtime.get("goal_path", ".absoloop/goal.md")
    delivery = runtime.get("delivery") or {"mode": "local"}
    delivery_detail = {"git": f"branch {delivery.get('branch', '?')}",
                       "out": delivery.get("out_dir", "?"),
                       "local": "working tree, unstaged"}.get(delivery.get("mode", "local"), "?")
    say(f"  goal {goal_path.relative_to(ROOT)}"
        + ("" if goal_path.is_file() else " (missing — using inline fallback)")
        + f" · delivery {delivery.get('mode', 'local')} ({delivery_detail})", "dim")
    say("  live view: run 'absoloop watch' in another terminal", "dim")
    MONITOR.update(mission_id=state.mission_id, loop_id=runtime.get("loop_id"),
                   objective=runtime.get("objective"), engine=args.engine,
                   model=model or None,
                   status="RUNNING", phase="preparing",
                   iteration=state.iteration,
                   max_iterations=int(runtime["max_iterations"]),
                   cost_usd=round(state.cost_usd, 4),
                   max_cost_usd=float(runtime["max_cost_usd"]),
                   tokens_total=state.tokens_total,
                   started_at=state.started_at, max_wall_seconds=max_wall,
                   repeated_failure_count=state.repeated_failure_count)
    if state.iteration:
        say(f"/goal active — resuming at iteration {state.iteration + 1} of "
            f"{runtime['max_iterations']}", "ok")
    else:
        say("/goal active — repair loop engaged", "ok")

    last_tree = tree_fingerprint()

    while state.iteration < int(runtime["max_iterations"]):
        if time.time() - state.started_at >= max_wall:
            # Resume keeps started_at — if the cap was already spent, say so
            # clearly instead of looking like a brand-new zero-work failure.
            if state.status == "BUDGET_EXHAUSTED" or (
                    state.iteration and time.time() - state.started_at > max_wall + 1):
                say("wall-clock budget already exhausted — use 'absoloop extend' "
                    "for a follow-on run with fresh budgets, or raise "
                    "max_wall_seconds in .absoloop/runtime.json then resume",
                    "err")
            return stop(state, "wall_clock_budget", "BUDGET_EXHAUSTED", runtime)
        if state.cost_usd >= float(runtime["max_cost_usd"]):
            return stop(state, "cost_budget", "BUDGET_EXHAUSTED", runtime)

        # Re-read the mission config so an operator fix to budgets takes
        # effect on the next iteration instead of being silently ignored for
        # the rest of the run.
        try:
            runtime = json.loads(RUNTIME_PATH.read_text(encoding="utf-8"))
            max_wall = float(runtime["max_wall_seconds"])
            check_timeout = min(900, int(max_wall))
        except (OSError, json.JSONDecodeError):
            say("warning: runtime.json unreadable right now — keeping previous config")

        state.iteration += 1
        state.status = "EXECUTING"
        checkpoint(state, "pre-agent")
        iter_tokens = (f" ({fmt_tokens(state.tokens_total)})"
                       if fmt_tokens(state.tokens_total) else "")
        say(f"iteration {state.iteration}/{runtime['max_iterations']} — "
            f"spent ${state.cost_usd:.2f}{iter_tokens} of "
            f"${float(runtime['max_cost_usd']):.2f}, "
            f"{int(max_wall - (time.time() - state.started_at))}s wall clock left",
            "bold")

        prompt = build_iteration_prompt(runtime, state, args.engine)
        prompt_path = TMP / f"iteration-{state.iteration:04d}-prompt.md"
        prompt_path.write_text(prompt, encoding="utf-8")
        if state.human_feedback:
            say("operator feedback delivered to the builder in this iteration's prompt")
            state.human_feedback = None  # consumed once; findings/logs carry forward
        rung = thinking_rung(runtime, state)
        scale = float(rung.get("budget_scale", 1.0))
        scale = scale if scale >= 1.0 else 1.0
        if args.engine == "claude":
            thinking_level = rung["claude_keyword"]
        elif args.engine == "grok":
            thinking_level = f"budget×{scale:g}"
        else:
            thinking_level = rung["codex_effort"]
        say(f"thinking level: {thinking_level} "
            f"(repeated failures: {state.repeated_failure_count}, "
            f"per-run budgets ×{scale:g})")
        MONITOR.update(phase="building", iteration=state.iteration,
                       max_iterations=int(runtime["max_iterations"]),
                       agent="builder", agent_started=time.time(),
                       thinking_level=thinking_level,
                       repeated_failure_count=state.repeated_failure_count,
                       status="EXECUTING", stop_reason=None)

        def scaled(cfg: dict[str, Any]) -> dict[str, Any]:
            # Deeper thinking needs room to run: widen this iteration's
            # wall-clock and cost caps by the rung's budget_scale. The
            # mission-level caps still bound total spend.
            cfg = dict(cfg)
            cfg["max_wall_seconds"] = int(float(cfg.get("max_wall_seconds", 1200)) * scale)
            cfg["max_budget_usd"] = round(float(cfg.get("max_budget_usd", 5.0)) * scale, 2)
            return cfg

        result_path = TMP / f"iteration-{state.iteration:04d}-agent-result.json"
        if args.engine == "claude":
            extra_env: dict[str, str] = {
                # Two-layer teams: enable Claude Agent Teams inside the builder.
                "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
            }
            tokens = rung.get("claude_thinking_tokens")
            if isinstance(tokens, (int, float)) and tokens > 0:
                # Real extended-thinking budget to match the prompt keyword.
                extra_env["MAX_THINKING_TOKENS"] = str(int(tokens))
            run = run_claude(prompt, scaled(runtime["claude"]["builder"]), result_path,
                             label="builder", extra_env=extra_env, model=model)
        elif args.engine == "grok":
            run = run_grok(prompt, scaled(runtime["grok"]["builder"]), result_path,
                           label="builder", model=model)
        else:
            builder_cfg = scaled(runtime["codex"]["builder"])
            configured = str(builder_cfg.get("model_reasoning_effort", "medium"))
            codex_effort = str(rung.get("codex_effort", configured))
            # Escalation only ever raises the configured effort, never lowers it.
            if CODEX_EFFORT_RANK.get(codex_effort, 2) > CODEX_EFFORT_RANK.get(configured, 2):
                builder_cfg["model_reasoning_effort"] = codex_effort
            run = run_codex(prompt, builder_cfg,
                            runtime["codex"].get("pricing"), result_path, RESULT_SCHEMA,
                            label="builder", model=model)

        state.cost_usd += run.cost_usd
        state.tokens_total += run.tokens or 0
        if not run.cost_is_exact:
            state.inexact_cost_events += 1
        report_spend(state, runtime)
        state.latest_agent_result = str(result_path.relative_to(ROOT))
        MONITOR.update(phase="assessing iteration", agent=None)
        render_agent_report(result_path, "builder")

        if run.exit_code != 0 or run.limit_reached:
            # A limit-terminated CLI run is a bounded failure, never completion.
            append_ledger({"type": "bounded_agent_failure", "iteration": state.iteration,
                           "exit_code": run.exit_code, "limit_reached": run.limit_reached})

        structured = agent_structured(result_path)
        builder_done = (run.exit_code == 0 and not run.limit_reached
                        and isinstance(structured, dict)
                        and structured.get("done") is True)
        append_ledger({
            "type": "iteration",
            "iteration": state.iteration,
            "done": builder_done,
        })

        # A done claim before the mission's iteration floor is noted but not
        # accepted: cheap first-iteration "everything already works" claims are
        # exactly how loops end after one run instead of doing the work.
        min_iter = int(runtime.get("min_iterations", 1) or 1)
        if builder_done and state.iteration < min_iter:
            say(f"builder reports done at iteration {state.iteration}, but "
                f"min_iterations is {min_iter} — not accepting yet; the next "
                "iteration must demonstrably improve the result", "warn")
            append_ledger({"type": "early_done_claim", "iteration": state.iteration,
                           "min_iterations": min_iter})
            builder_done = False

        if builder_done:
            checkpoint(state, "builder-done")
            verdict = final_acceptance(runtime, state, args.engine, check_timeout,
                                       model=model)

            if verdict is not None:
                return stop(state, *verdict, runtime)
            checkpoint(state, "critic-hold")
            continue  # critic HOLD: findings feed the next repair iteration

        # No-progress detection: an iteration that neither finishes the
        # mission nor changes the working tree is a stall. Repeated stalls
        # climb the thinking ladder and eventually block the loop.
        current_tree = tree_fingerprint()
        if current_tree is None and isinstance(structured, dict):
            current_tree = normalized_fingerprint(str(structured.get("summary", "")))
        if current_tree is not None and current_tree == last_tree:
            state.repeated_failure_count += 1
            state.last_failure_fingerprint = current_tree
            say(f"no changes made this iteration ({state.repeated_failure_count} "
                f"stalled in a row; loop stops at {runtime['no_progress_window']})",
                "warn")
        else:
            state.repeated_failure_count = 0
            state.last_failure_fingerprint = current_tree
        last_tree = current_tree

        checkpoint(state, "post-iteration")

        if state.repeated_failure_count >= int(runtime["no_progress_window"]):
            return stop(state, "no_progress_window", "BLOCKED", runtime)

    return stop(state, "iteration_budget", "BUDGET_EXHAUSTED", runtime)


if __name__ == "__main__":
    raise SystemExit(main())
