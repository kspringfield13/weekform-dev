{
  "name": "weekform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "lint": "biome lint .",
    "dev": "vite --host 127.0.0.1",
    "demo": "vite --host 127.0.0.1 --open '/?demo=1&screen=weekly'",
    "tauri": "tauri",
    "desktop:dev": "DEVELOPER_DIR=${DEVELOPER_DIR:-/Library/Developer/CommandLineTools} tauri dev",
    "desktop:build": "DEVELOPER_DIR=${DEVELOPER_DIR:-/Library/Developer/CommandLineTools} tauri build",
    "desktop:release:mac": "DEVELOPER_DIR=${DEVELOPER_DIR:-/Library/Developer/CommandLineTools} CARGO_BUILD_JOBS=${CARGO_BUILD_JOBS:-2} tauri build --target universal-apple-darwin --bundles app,dmg",
    "test:simulator": "node --import tsx --test packages/simulator/src/*.test.ts",
    "test:cloud": "node --import tsx --test packages/inference/src/*.test.ts",
    "test:desktop-cloud": "node --import tsx --test apps/desktop/src/services/*.test.ts",
    "test:desktop-ui": "node --import tsx --test apps/desktop/src/components/settings/*.test.ts apps/desktop/src/hooks/*.test.ts apps/desktop/src/lib/*.test.ts",
    "test:integrations": "node --import tsx --test packages/integrations/src/calendar/*.test.ts packages/integrations/src/chat/*.test.ts",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "test:release-scripts": "node --test scripts/*.test.mjs apps/web/scripts/*.test.mjs",
    "test:web:static": "node --import tsx --test apps/web/lib/*.test.ts",
    "test:web": "npm run test:web:static",
    "test:supabase:rls": "supabase test db --local supabase/tests",
    "test:release:app": "npm run test:cloud && npm run test:desktop-cloud && npm run test:desktop-ui && npm run test:integrations && npm run test:simulator && npm run test:web && npm run test:release-scripts && npm run test:supabase:rls",
    "test:release": "npm run test:release:app && npm run test:rust",
    "web:typecheck": "npm --prefix apps/web run typecheck",
    "verify:web:release": "npm run web:typecheck && npm run test:web:static && npm run test:supabase:rls && npm run web:build",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "validate:cloud": "npm run test:cloud && npm run web:build",
    "verify:cloud-web": "npm run test:desktop-cloud && npm run test:web && npm run web:build",
    "verify:wave2": "npm run verify:cloud-web",
    "verify:wave3": "npm run verify:cloud-web",
    "verify:release": "npm run web:typecheck && npm run test:release && npm run build && npm run web:build && npm run audit:check",
    "build": "tsc -b && npm run pricing:check && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "audit:check": "npm audit --json && npm --prefix apps/web audit --json",
    "audit:fix:web": "npm --prefix apps/web install",
    "pricing:check": "node scripts/refresh-model-prices.mjs --check",
    "pricing:refresh": "node scripts/refresh-model-prices.mjs",
    "pricing:refresh:apply": "node scripts/refresh-model-prices.mjs --apply"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.86",
    "@ai-sdk/openai-compatible": "2.0.62",
    "@fontsource-variable/geist": "^5.2.9",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.1.0",
    "ai": "6.0.230",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "three": "0.185.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
