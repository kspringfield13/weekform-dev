# Copy this file to .env and add your local credentials.
# Never commit a populated .env file.
OPENAI_API_KEY=

# Optional model overrides. Leave blank to use the app defaults.
OPENAI_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.5

# Optional desktop calendar live sync. These are public native-app OAuth client
# identifiers, never client secrets. Apple Calendar uses macOS EventKit instead.
GOOGLE_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_ID=

# Optional desktop Chat connections. These are public native-app/integration
# client identifiers, never client secrets. Slack and Google Chat exchange
# tokens directly from the Mac with PKCE. Webex additionally requires the
# exact registered loopback callback and the HTTPS base of Weekform's token-only
# broker; this repository's route is reached with a base such as
# https://weekform.dev/api (the Mac appends /oauth/webex/token).
# Slack's manifest-registered callback is http://localhost:49324/chat-auth/callback.
# These build defaults are optional because all public connection details can
# also be saved from Settings > Data Sources > Chat in the native Mac app. The
# Webex secret and security attestation remain server/release controlled.
SLACK_CHAT_CLIENT_ID=
GOOGLE_CHAT_CLIENT_ID=
WEBEX_CHAT_CLIENT_ID=
WEBEX_CHAT_REDIRECT_URI=http://127.0.0.1:49323/chat-auth/callback
WEEKFORM_CHAT_OAUTH_BROKER_URL=
# Set to true only after the deployed broker has verified rate limiting and
# credential-safe request, proxy, and observability logging. Webex fails closed
# when this operational attestation is absent or false.
WEBEX_CHAT_BROKER_SECURITY_VERIFIED=false

# Optional maintainer-only credential. Used by `npm run pricing:refresh` to
# create a reviewable candidate catalog; it is never bundled into the app.
FIRECRAWL_API_KEY=

# Development-only synthetic workload laboratory. Production authorization
# must be enforced by Supabase RLS, never by these client flags.
VITE_ENABLE_SPAN_SIMULATOR=false

# Optional Weekform Cloud (Account & Sharing) endpoint: publishable URL + anon
# key only — row access is enforced by Supabase RLS, and there is NO secret or
# service key in the desktop app. Leave blank to keep the app fully local
# (cloud features render an honest "not configured" state).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional web-app origin used by Manager Access and Account & Sharing links.
# Defaults to https://weekform.dev; set this for local, staging, or production.
VITE_WEEKFORM_WEB_URL=
