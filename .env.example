# Copy this file to .env and add your local credentials.
# Never commit a populated .env file.
OPENAI_API_KEY=

# Optional model overrides. Leave blank to use the app defaults.
OPENAI_MODEL=gpt-5.5
OPENAI_VISION_MODEL=gpt-5.5

# Optional maintainer-only credential. Used by `npm run pricing:refresh` to
# create a reviewable candidate catalog; it is never bundled into the app.
FIRECRAWL_API_KEY=

# Development-only synthetic workload laboratory. Production authorization
# must be enforced by Supabase RLS, never by these client flags.
VITE_ENABLE_SPAN_SIMULATOR=false
VITE_ENABLE_SPAN_SIMULATOR_PLAYBACK=false
