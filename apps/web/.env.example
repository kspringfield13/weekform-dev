# Supabase project configuration (publishable values only).
# Every page/action/query in this app uses only these two values plus the
# signed-in user's cookie session — row access is enforced by Supabase RLS.
#
# Find these in your Supabase dashboard under Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: the official packaged Mac artifact, served via a short-lived
# signed URL from a private Supabase Storage bucket. All of
# WEEKFORM_ARTIFACT_BUCKET, WEEKFORM_ARTIFACT_PATH, NEXT_PUBLIC_SUPABASE_URL
# (above), SUPABASE_SERVICE_ROLE_KEY, and every release-proof value below must
# be set for /download/artifact to serve the signed-URL path. The proof values
# are release-pipeline attestations, not a substitute for running the listed
# checks against the exact uploaded DMG. If any value is missing or invalid,
# /download keeps the release action visibly unavailable. Never set an
# attestation to true before the check succeeds. SUPABASE_SERVICE_ROLE_KEY is
# a SECRET used only by this artifact-delivery boundary.
# It is read only in the server route handler
# (apps/web/app/download/artifact/route.ts) and is never sent to the
# browser or bundled client-side. See apps/web/README.md for how to upload
# the artifact and set these.
WEEKFORM_ARTIFACT_BUCKET=
# Current release shape: releases/stable/<sha256>/Weekform_0.1.0_universal.dmg
WEEKFORM_ARTIFACT_PATH=
SUPABASE_SERVICE_ROLE_KEY=
# Set these only after Developer ID verification, notarization, stapler
# validation, and checksum verification succeed for WEEKFORM_ARTIFACT_PATH.
WEEKFORM_ARTIFACT_DEVELOPER_ID_SIGNED=false
WEEKFORM_ARTIFACT_NOTARIZED=false
WEEKFORM_ARTIFACT_STAPLED=false
WEEKFORM_ARTIFACT_SHA256=
# Canonical UTC timestamp for the completed run: YYYY-MM-DDTHH:mm:ss.sssZ
WEEKFORM_ARTIFACT_VERIFIED_AT=
# Optional; defaults to 300 seconds (5 minutes), clamped to 30-3600.
WEEKFORM_ARTIFACT_SIGNED_URL_TTL_SECONDS=

# Optional temporary Beta Version channel. This is intentionally separate
# from the trusted release above and must never set notarized/stapled claims.
WEEKFORM_BETA_ARTIFACT_BUCKET=
WEEKFORM_BETA_ARTIFACT_PATH=
WEEKFORM_BETA_ARTIFACT_DEVELOPER_ID_SIGNED=false
WEEKFORM_BETA_ARTIFACT_SHA256=
WEEKFORM_BETA_ARTIFACT_VERIFIED_AT=
WEEKFORM_BETA_ARTIFACT_SIGNED_URL_TTL_SECONDS=

# Team Briefing Agent (apps/web/lib/briefing.ts) — SERVER-ONLY, optional.
# Both vars are read only in server actions/route handlers; they are never
# sent to the browser and never prefixed with NEXT_PUBLIC_. If either is
# unset, the Team Briefing feature runs in deterministic-fallback mode
# (a summary built from risk flags only, no model call).
#
# OPENAI_TEAM_BRIEFING_MODEL must be a real, currently available OpenAI
# model ID verified against official OpenAI documentation — never guess or
# freeze an unverified ID here. Prefer a current GPT-5.6 model when
# available in your account.
OPENAI_API_KEY=
OPENAI_TEAM_BRIEFING_MODEL=

# Individual Web Ask (apps/web/lib/personalAgent.ts) — SERVER-ONLY, optional.
# This model is configured independently from Team Briefing so enabling a
# manager workflow cannot silently enable processing of individual questions.
# When unset, Web Ask returns a labeled deterministic answer and makes no model
# request. Use a current model ID verified against official OpenAI documentation;
# never guess or expose this variable with a NEXT_PUBLIC_ prefix.
OPENAI_PERSONAL_AGENT_MODEL=

# Webex Chat OAuth broker — SERVER-ONLY, optional. Webex requires a confidential
# client secret even when PKCE is used. This route exchanges authorization and
# refresh credentials only; message data never transits weekform.dev. Register
# this exact loopback callback in the Webex integration and configure the Mac
# with WEEKFORM_CHAT_OAUTH_BROKER_URL=<this-site-origin>/api.
WEBEX_CHAT_CLIENT_ID=
WEBEX_CHAT_CLIENT_SECRET=
WEBEX_CHAT_REDIRECT_URI=http://127.0.0.1:49323/chat-auth/callback
# Set to true only after deployed rate limiting and credential-safe request,
# proxy, and observability logging have been verified. The route returns 503
# while this operational attestation is absent or false.
WEBEX_CHAT_BROKER_SECURITY_VERIFIED=false

# Distributed provider controls — SERVER-ONLY and required whenever either
# OpenAI model path or the Webex broker is enabled. Generate two independent
# random values of at least 32 bytes. The IP secret HMACs the trusted proxy IP;
# raw IP addresses are never stored. Vercel overwrites x-forwarded-for at its
# edge; alternate or comma-delimited forwarding headers fail closed.
REQUEST_CONTROL_SERVER_CLAIM=
REQUEST_CONTROL_IP_HASH_SECRET=
REQUEST_CONTROL_TRUSTED_IP_HEADER=x-forwarded-for
REQUEST_CONTROL_TRUSTED_PROXY=vercel
# Supabase must also receive SHA-256(REQUEST_CONTROL_SERVER_CLAIM) as the
# database setting app.settings.request_control_server_claim_sha256. Store only
# the digest in Postgres, never either plaintext server secret.
