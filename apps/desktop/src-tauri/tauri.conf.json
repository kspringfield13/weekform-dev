{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weekform",
  "version": "0.1.0",
  "identifier": "com.clearcapacity.desktop",
  "build": {
    "frontendDist": "../../../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Weekform",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720,
        "visible": false,
        "skipTaskbar": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "Local workload intelligence for sustainable performance.",
    "longDescription": "Weekform turns reviewable local work signals into explainable weekly capacity, delivery risk, and grounded decisions about what fits next.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 220
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 220
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
